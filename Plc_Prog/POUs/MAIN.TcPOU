    <Method Name="_001_FirstScan" Id="{2b51631a-b1de-4251-88c9-0f83eb7f4089}">
      <Declaration><![CDATA[METHOD _001_FirstScan
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
(*

paperMachineHmiCommands.dryingSectionGroup1SteamPressureAutoMan := FALSE;

	dryingSectionGroup1SteamPressureAutoSetpoint : REAL;  // Recovery speed increment [m/min or %] (Incremento de recuperação Grupo 1)
	dryingSectionGroup1SteamPressureManualSetpoint : REAL;  // Recovery speed increment [m/min or %] (Incremento de recuperação Grupo 1)
	
*)



paperMachineHmiCommands.dryingSectionGroup1SteamPressureAutoMan := FALSE;
paperMachineHmiCommands.dryingSectionGroup1SteamPressureManualSetpoint := 0.0;

paperMachineHmiCommands.dryingSectionGroup2SteamPressureAutoMan := FALSE;
paperMachineHmiCommands.dryingSectionGroup2SteamPressureManualSetpoint := 0.0;

paperMachineHmiCommands.dryingSectionGroup3SteamPressureAutoMan := FALSE;
paperMachineHmiCommands.dryingSectionGroup3SteamPressureManualSetpoint := 0.0;


//Reset first scan flag
firstScan := FALSE;]]></ST>
      </Implementation>
    </Method>
