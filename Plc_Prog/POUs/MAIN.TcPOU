//────────────────────────────────────────────
// READ DRIVES
//────────────────────────────────────────────

// Press Section
P11_400_UG01_SecondPress();     // Second Press
P12_400_UG01_FirstPress();      // First Press

// Drying Section — Group 1
P13_500_UG01_1GR_UpperSlave();  // Group 1 - Upper Slave
P13_500_UG02_1GR_LowerMaster(); // Group 1 - Lower Master
P13_500_UG03_1GR_UpperMaster(); // Group 1 - Upper Master

// Drying Section — Group 2
P13_501_UG01_2GR_LowerSlave();  // Group 2 - Lower Slave
P13_501_UG02_2GR_UpperSlave();  // Group 2 - Upper Slave
P13_501_UG03_2GR_LowerMaster(); // Group 2 - Lower Master
P14_501_UG01_2GR_UpperMaster(); // Group 2 - Upper Master

// Drying Section — Group 3
P14_502_UG01_3GR_LowerSlave();  // Group 3 - Lower Slave
P14_502_UG02_3GR_UpperSlave();  // Group 3 - Upper Slave
P14_502_UG03_3GR_LowerMaster(); // Group 3 - Lower Master
P14_502_UG04_3GR_UpperMaster(); // Group 3 - Upper Master

//Winder group
P15_600_UG01_Rewinder();
//────────────────────────────────────────────
// PROGRAM FUNCTION BLOCK CALLS
//────────────────────────────────────────────

// Forming Section
_100_FormingBoardControl();
_110_FormingBoardAux();

// Press Section
_200_PressSectionControl();

// Drying Section
