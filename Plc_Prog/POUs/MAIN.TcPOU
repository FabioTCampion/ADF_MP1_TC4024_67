    <Method Name="_200_PressSectionControl" Id="{9f824a2c-9679-4031-8e2d-18b1073be726}">
      <Declaration><![CDATA[METHOD _200_PressSectionControl
VAR_INPUT
END_VAR
(*

P1_200_UG01();	//First press group master motor
P1_200_UG02();	//First press group slave motor
	
P1_300_UG01();	//First drying group master motor
P1_300_UG02();	//First drying group slave 1
P1_300_UG03();	//First drying group slave 2
	
P1_400_UG01();	//Second drying group master motor
P1_400_UG02();	//Second drying group slave 1
P1_400_UG03();	//Second drying group slave 2

*)]]></Declaration>
