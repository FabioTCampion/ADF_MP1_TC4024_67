upperMaster_3GR_speedSetpoint:= (P14_502_UG04_3GR_UpperMaster.pdoSpeedSet);//1064

rewinder_speedSetpoint:= (P15_600_UG01_Rewinder.pdoSpeedSet);//1065

// NOTE:
// - You had duplicated CASE label "2:" twice. The second one must be "3:" (1053).
// - Below continues the sequence following your exact pattern.


bExecute := TRUE;

CASE adsWriteState OF

    0:
        fbSdoWrite(
            sNetId     := '192.168.100.1.3.1',
            nSlaveAddr := 1021,
            nIndex     := 16#3004,
            nSubIndex  := 1,
            pSrcBuf    := ADR(sctionRoll_speedSetpoint),
            cbBufLen   := SIZEOF(sctionRoll_speedSetpoint),
            bExecute   := bExecute
        );

        IF NOT fbSdoWrite.bBusy THEN
            bExecute := FALSE;
            IF NOT fbSdoWrite.bError THEN
                bError := FALSE;
                nErrId := 0;
                adsWriteState := adsWriteState + 1;
            ELSE
                bError := fbSdoWrite.bError;
                nErrId := fbSdoWrite.nErrId;
                adsWriteState := adsWriteState + 1;
				
            END_IF

            fbSdoWrite(bExecute := FALSE);
        END_IF

