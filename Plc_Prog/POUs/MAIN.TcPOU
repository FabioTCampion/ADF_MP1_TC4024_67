    <Method Name="machineReset" Id="{02d7d166-7912-45b0-ae8c-bd34367b2eb6}">
      <Declaration><![CDATA[METHOD machineReset
VAR_INPUT
END_VAR

VAR
	instTP_Reset: TP;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[//────────────────────────────────────────────
// UG01 to UG06 (General Utilities / Aux Drives)
//────────────────────────────────────────────
P1_100_UG01.commandWord.faultResetCmd := paperMachineHmiCommands.machineReset;
P1_100_UG02.commandWord.faultResetCmd := paperMachineHmiCommands.machineReset;
P1_100_UG03_SuctionRoll.commandWord.faultResetCmd := paperMachineHmiCommands.machineReset;
P1_100_UG04.commandWord.faultResetCmd := paperMachineHmiCommands.machineReset;
P1_100_UG05.commandWord.faultResetCmd := paperMachineHmiCommands.machineReset;
P1_300_UG06_TractionRoll.commandWord.faultResetCmd := paperMachineHmiCommands.machineReset;

//────────────────────────────────────────────
// Safety PLC Reset
//────────────────────────────────────────────
P1_050_SP1.safetyReset := paperMachineHmiCommands.machineReset;
P1_050_SP1.errorAcknowledgement := paperMachineHmiCommands.machineReset;

//────────────────────────────────────────────
// Press Section Drives
//────────────────────────────────────────────
P11_400_UG01_SecondPress.commandWord.faultResetCmd := paperMachineHmiCommands.machineReset;
P12_400_UG01_FirstPress.commandWord.faultResetCmd := paperMachineHmiCommands.machineReset;

//────────────────────────────────────────────
// Drying Section — Group 1
//────────────────────────────────────────────
P13_500_UG01_1GR_UpperSlave.commandWord.faultResetCmd := paperMachineHmiCommands.machineReset;
P13_500_UG02_1GR_LowerMaster.commandWord.faultResetCmd := paperMachineHmiCommands.machineReset;
P13_500_UG03_1GR_UpperMaster.commandWord.faultResetCmd := paperMachineHmiCommands.machineReset;

//────────────────────────────────────────────
// Drying Section — Group 2
//────────────────────────────────────────────
P13_501_UG01_2GR_LowerSlave.commandWord.faultResetCmd := paperMachineHmiCommands.machineReset;
P13_501_UG02_2GR_UpperSlave.commandWord.faultResetCmd := paperMachineHmiCommands.machineReset;
P13_501_UG03_2GR_LowerMaster.commandWord.faultResetCmd := paperMachineHmiCommands.machineReset;
P14_501_UG01_2GR_UpperMaster.commandWord.faultResetCmd := paperMachineHmiCommands.machineReset;

//────────────────────────────────────────────
// Drying Section — Group 3
//────────────────────────────────────────────
P14_502_UG01_3GR_LowerSlave.commandWord.faultResetCmd := paperMachineHmiCommands.machineReset;
P14_502_UG02_3GR_UpperSlave.commandWord.faultResetCmd := paperMachineHmiCommands.machineReset;
P14_502_UG03_3GR_LowerMaster.commandWord.faultResetCmd := paperMachineHmiCommands.machineReset;
P14_502_UG04_3GR_UpperMaster.commandWord.faultResetCmd := paperMachineHmiCommands.machineReset;

//────────────────────────────────────────────
// Rewinder
//────────────────────────────────────────────
P15_600_UG01_Rewinder.commandWord.faultResetCmd := paperMachineHmiCommands.machineReset;
]]></ST>
      </Implementation>
    </Method>
