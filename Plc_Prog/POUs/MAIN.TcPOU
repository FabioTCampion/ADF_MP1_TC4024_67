_StockPumpControl_1();

// Testing & Debug
_FunctionBlockTest();

//────────────────────────────────────────────
// SYSTEM MANAGEMENT
//────────────────────────────────────────────

// Save persistent variables to CPU
instFB_SavePersistentData();

// Enable Safety PLC
P1_050_SP1.run := TRUE;

// Perform machine-wide reset
machineReset();


rInitVariables := initVariables AND NOT initVariablesOld;

IF rInitVariables THEN
	
	_000_Init_Variables();

END_IF

initVariablesOld := initVariables;



IF firstScan THEN
	
	_001_FirstScan();

END_IF


sctionRoll_speedSetpoint:= (P1_100_UG03_SuctionRoll.pdoSpeedSet); //Address 1021
tractionRoll_speedSetpoint := (P1_300_UG06_TractionRoll.pdoSpeedSet); //Addres 1024

secondPress_speedSetpoint := (P11_400_UG01_SecondPress.pdoSpeedSet); //1052
firstPress_speedSetpoint := (P12_400_UG01_FirstPress.pdoSpeedSet); //1053

upperSlave_1GR_speedSetpoint := (P13_500_UG01_1GR_UpperSlave.pdoSpeedSet); //1054
lowerMaster_1GR_speedSetpoint := (P13_500_UG02_1GR_LowerMaster.pdoSpeedSet);//1055
upperMaster_1GR_speedSetpoint := (P13_500_UG03_1GR_UpperMaster.pdoSpeedSet);//1056

lowerSlave_2GR_speedSetpoint:= (P13_501_UG01_2GR_LowerSlave.pdoSpeedSet);//1057
upperSlave_2GR_speedSetpoint:= (P13_501_UG02_2GR_UpperSlave.pdoSpeedSet);//1058
lowerMaster_2GR_speedSetpoint:= (P13_501_UG03_2GR_LowerMaster.pdoSpeedSet);//1059
upperMaster_2GR_speedSetpoint:= (P14_501_UG01_2GR_UpperMaster.pdoSpeedSet);//1060

