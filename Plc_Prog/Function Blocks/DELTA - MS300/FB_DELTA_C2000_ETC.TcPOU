<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="FB_DELTA_C2000_ETC" Id="{ab925d78-566b-0e7c-0e54-6c559f991a26}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_DELTA_C2000_ETC



//======================================================================
// Persistent Configuration Inputs
//======================================================================
VAR_INPUT PERSISTENT
	
    deviceConfig            : C2000_DEV_CONFIG;       // Device-specific configuration (scaling, limits, etc.)

END_VAR

//======================================================================
// Runtime Inputs
//======================================================================
VAR_INPUT
	
    speedSetpoint           : REAL;                		// Motor speed reference to be written to drive
	torqueSetpoint			: REAL;						// Torque limit if running as torque
    commandWord             : C2000_CONTROLWORD;      	// Control word to drive (start, stop, etc.)
    digitalOutputs          : C2000_DIGITAL_OUTPUTS;  	// Digital output values to send to drive
    analogOutputs           : C2000_ANALOG_OUTPUTS;   	// Analog output values to send to drive
	
END_VAR

//======================================================================
// Runtime Outputs
//======================================================================
VAR_OUTPUT
	
    statusWord              : C2000_STATUSWORD;       // Current status word read from drive
    digitalInputs           : C2000_DIGITAL_INPUTS;   // Current status of digital inputs from drive
    analogInputs            : C2000_ANALOG_INPUTS;    // Current status of analog inputs from drive
    motorSpeedRPM             : REAL;                   // Actual motor speed read from drive in RPM
    motorSpeedEng             : REAL;                   // Actual motor speed read from drive in enginering units scaled
    outputCurrent           : REAL;                   // Output current read from drive
    outputTorque            : REAL;                   // Output torque read from drive
	
	
	pdoSpeedSet			: INT;
	
	
END_VAR

//======================================================================
// Internal Variables
//======================================================================
VAR
    PDOS                    : C2000_PDOS;             // Process Data Object structure containing drive mappings
    // One-shot + pulse for fault reset
    rTrigReset : R_TRIG;
    tReset     : TOF;
	
    // Base OMS bits default (keep your logic)
    b0_swOn, b1_enVolt, b2_qStopOK, b3_enOp : BOOL;
    b4, b5, b6, b7_faultReset, b8_halt      : BOOL;
    cw                                       : WORD;

    // Reset sequencer helpers
 //   rTrigReset        : R_TRIG;   // detect rising edge of reset command
    tResetClear       : TON;      // phase 1: clear all bits (control word = 0)
    tResetPulse       : TON;      // phase 2: pulse bit7 = 1
    resetSeqActive    : BOOL;     // TRUE while running either phase
    resetClearPt      : TIME := T#500MS;    // adjust if your drive needs longer clear
    resetPulsePt      : TIME := T#1000ms;  // 1 second fault-reset pulse	

END_VAR

]]></Declaration>
    <Implementation>
      <ST><![CDATA[(*==============================================================================================================================
CPNTeck - Automação Industrial
(c)Copyright 2025 All Rights Reserved
_______________________________________________________________________________________________________________________________
Library: N/A
Tested with: CX920
Engineering: TwinCAT 3
Restrictions: -
Requirements: N/A
Functionality: This function block communicates with a Delta MS300 drive over Modbus RTU. It reads process values such as
               motor speed, current, torque, status words, digital and analog inputs, and writes control commands and 
               setpoints to the drive. The block includes timeout monitoring and state-based communication handling.
Support: fabio@cpnteck.com.br
Note: Parameter comments are only available in language 'English (United States)'

_______________________________________________________________________________________________________________________________
Change log table:

Version         | Date         | Expert in charge   | Changes applied
01.00.01        | 31.05.2025   | Fabio Campion      | Initial implementation for MS300 drive Modbus RTU communication
==============================================================================================================================*)

_StatusWord();       // Method to handle the status word of the drive
_DigitalInputs();    // Method to process the status of digital inputs
_AnalogInputs();     // Method to handle analog input values

_CommandWord();      // Method to set or process the command word for the drive
_DigitalOutputs();   // Method to manage the status of digital outputs
_AnalogOutputs();    // Method to handle analog output values
_SetOperationMode();
_FeedBackVariables(); // Method to process feedback variables from the drive
_SpeedReference();         // Method to set or process the setpoint values
_TorqueReference();]]></ST>
    </Implementation>
