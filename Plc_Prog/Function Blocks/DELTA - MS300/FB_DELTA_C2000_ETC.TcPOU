      </Implementation>
    </Method>
    <Method Name="_AnalogOutputs" Id="{e7f1d51d-9feb-06a1-0781-10b513afd3f5}">
      <Declaration><![CDATA[METHOD PRIVATE _AnalogOutputs
VAR_INPUT
END_VAR
]]></Declaration>
