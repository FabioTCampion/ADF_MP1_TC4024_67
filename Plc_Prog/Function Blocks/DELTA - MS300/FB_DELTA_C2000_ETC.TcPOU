      </Implementation>
    </Method>
    <Method Name="_CommandWord" Id="{c40c1f05-2112-0c7f-3630-534ce343c155}">
      <Declaration><![CDATA[METHOD PRIVATE _CommandWord
VAR_INPUT
END_VAR
(*
VAR
    // Internal
    b0_swOn, b1_enVolt, b2_qStopOK, b3_enOp, b4, b5, b6 : BOOL;
    b7_faultReset, b8_halt                              : BOOL;
    cw                                                  : UINT;
END_VAR
*)]]></Declaration>
      <Implementation>
        <ST><![CDATA[
b4 := 1;
b5 := 1;
b6 := 1;


// ---------- 1) Base state from commands (bits 0..3) ----------
IF commandWord.quickStop THEN
    // Quick-stop has highest priority: keep voltage/switch-on, clear enable op, force bit2=0
    b0_swOn    := TRUE;
    b1_enVolt  := TRUE;
    b2_qStopOK := FALSE;  // bit2=0 => quick stop active
    b3_enOp    := FALSE;

ELSIF commandWord.enableDrive THEN
    // Enable Operation: 1,1,1,1
    b0_swOn    := TRUE;
    b1_enVolt  := TRUE;
    b2_qStopOK := TRUE;
    b3_enOp    := TRUE;

ELSIF commandWord.stopRequest THEN
    // Switch On (ready but not enabled): 1,1,1,0
    b0_swOn    := TRUE;
    b1_enVolt  := TRUE;
    b2_qStopOK := TRUE;
    b3_enOp    := FALSE;

ELSE
    // Shutdown (safe, DC bus on): 0,1,1,0
    b0_swOn    := FALSE;
    b1_enVolt  := TRUE;
    b2_qStopOK := TRUE;
    b3_enOp    := FALSE;
END_IF


// ---------- 2) Halt (bit8) ----------
b8_halt := commandWord.halt;

// ---------- 3) Fault Reset as 1000 ms pulse (bit7) ----------
rTrigReset(CLK := commandWord.faultResetCmd);
tReset(IN := rTrigReset.Q, PT := T#1000ms);
b7_faultReset := tReset.Q;

// ---------- 4) Pack bits into 16-bit control word ----------
cw := 0; // bits 9..15 remain 0 unless you set them later

// base (0..3)
IF b0_swOn    THEN cw := cw OR 16#0001; END_IF; // bit0
IF b1_enVolt  THEN cw := cw OR 16#0002; END_IF; // bit1
IF b2_qStopOK THEN cw := cw OR 16#0004; END_IF; // bit2
IF b3_enOp    THEN cw := cw OR 16#0008; END_IF; // bit3

// OMS (4..6) — use correct masks
IF b4          THEN cw := cw OR 16#0010; END_IF; // bit4
IF b5          THEN cw := cw OR 16#0020; END_IF; // bit5
IF b6          THEN cw := cw OR 16#0040; END_IF; // bit6

// bit7 (fault reset pulse) and bit8 (halt)
IF b7_faultReset THEN cw := cw OR 16#0080; END_IF; // bit7
IF b8_halt       THEN cw := cw OR 16#0100; END_IF; // bit8

// Bits 9..15 reserved = 0
PDOS.PlcToDrv.controlWord := cw;



//==============================================================
// CIA402 CONTROL WORD BUILD — with proper reset sequence
//==============================================================
(*

//==============================================================
// 0) Edge-detect RESET command and run the two-phase sequence
//==============================================================
rTrigReset(CLK := commandWord.faultResetCmd);

// Start sequence on rising edge
IF rTrigReset.Q THEN
    resetSeqActive := TRUE;
    // (Re)start clear phase
    tResetClear(IN := TRUE, PT := resetClearPt);
    // ensure pulse is off until clear finishes
    tResetPulse(IN := FALSE, PT := resetPulsePt);
END_IF;

// Advance/reset timers when sequence is active
IF resetSeqActive THEN
    // Phase 1: CLEAR (control word = 0)
    tResetClear(IN := tResetClear.IN, PT := resetClearPt);

    // When clear finishes, start pulse (only once)
    IF tResetClear.Q AND NOT tResetPulse.IN THEN
        tResetClear(IN := FALSE, PT := resetClearPt);     // stop clear timer
        tResetPulse(IN := TRUE,  PT := resetPulsePt);     // start pulse
    END_IF;

    // Run pulse
    tResetPulse(IN := tResetPulse.IN, PT := resetPulsePt);

    // Sequence ends when pulse finishes
    IF tResetPulse.Q THEN
        tResetPulse(IN := FALSE, PT := resetPulsePt);
        resetSeqActive := FALSE;
    END_IF;
END_IF;


//==============================================================
// 1) NORMAL PACKING (only used when NOT resetting)
//==============================================================

// Default OMS high (per your original)
b4 := TRUE;  // bit4 mask 0x0010
b5 := TRUE;  // bit5 mask 0x0020
b6 := TRUE;  // bit6 mask 0x0040

// ---------- 1) Base state from commands (bits 0..3) ----------
IF commandWord.quickStop THEN
    // Quick-stop has highest priority
    b0_swOn    := TRUE;
    b1_enVolt  := TRUE;
    b2_qStopOK := FALSE; // quick stop active
    b3_enOp    := FALSE;

ELSIF commandWord.enableDrive THEN
    // Enable Operation: 1,1,1,1
    b0_swOn    := TRUE;
    b1_enVolt  := TRUE;
    b2_qStopOK := TRUE;
    b3_enOp    := TRUE;

ELSIF commandWord.stopRequest THEN
    // Switch On (ready but not enabled): 1,1,1,0
    b0_swOn    := TRUE;
    b1_enVolt  := TRUE;
    b2_qStopOK := TRUE;
    b3_enOp    := FALSE;

ELSE
    // Shutdown (safe, DC bus on): 0,1,1,0
    b0_swOn    := FALSE;
    b1_enVolt  := TRUE;
    b2_qStopOK := TRUE;
    b3_enOp    := FALSE;
END_IF;

// ---------- 2) Halt (bit8) ----------
b8_halt := commandWord.halt;


//==============================================================
// 2) BUILD CONTROL WORD — with RESET SEQUENCE OVERRIDE
//==============================================================
cw := 0;

// If reset sequence is active, override everything
IF resetSeqActive THEN
    // Phase 1: CLEAR → send 0x0000
    IF NOT tResetClear.Q THEN
//        cw := 16#0000;
        cw := 16#0080;
		

    // Phase 2: PULSE → send only bit7 = 1 (0x0080)
    ELSIF tResetClear.Q AND NOT tResetPulse.Q THEN
//        cw := 16#0080;
        cw := 16#0000;
		
    END_IF;

ELSE
    // Normal packing
    // base (0..3)
    IF b0_swOn    THEN cw := cw OR 16#0001; END_IF; // bit0
    IF b1_enVolt  THEN cw := cw OR 16#0002; END_IF; // bit1
    IF b2_qStopOK THEN cw := cw OR 16#0004; END_IF; // bit2
    IF b3_enOp    THEN cw := cw OR 16#0008; END_IF; // bit3

    // OMS (4..6)
    IF b4          THEN cw := cw OR 16#0010; END_IF; // bit4
    IF b5          THEN cw := cw OR 16#0020; END_IF; // bit5
    IF b6          THEN cw := cw OR 16#0040; END_IF; // bit6

    // bit7 (fault reset) — now driven EXCLUSIVELY by the sequencer, so keep low here
    // b7_faultReset := FALSE;

    // bit8 (halt)
    IF b8_halt       THEN cw := cw OR 16#0100; END_IF; // bit8

    // Bits 9..15 remain 0 unless set elsewhere
END_IF;

// Push to PDO
PDOS.PlcToDrv.controlWord := cw;
*)
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_DigitalInputs" Id="{a5dbc0ab-d2e5-0786-242b-806535b5e503}">
