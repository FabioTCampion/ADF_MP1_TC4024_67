    <Method Name="_FeedBackVariables" Id="{7111ba05-eac4-0a06-3f22-f91bad671040}">
      <Declaration><![CDATA[METHOD PRIVATE _FeedBackVariables
VAR_INPUT
END_VAR

VAR
	
	OutputTorqueAux : REAL;

END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Calculate the actual motor speed
motorSpeedRPM := DINT_TO_REAL(PDOS.DrvToPLC.velocityActualValue);
// Calculate the actual motor speed in meters per minute
motorSpeedEng := _Scale(
    X := DINT_TO_REAL(PDOS.DrvToPLC.velocityActualValue), 
    I_LO := deviceConfig.MotorSpeedInputLow, 
    I_HI := deviceConfig.MotorSpeedInputHigh, 
    O_LO := deviceConfig.MotorSpeedMPMOutputLow, 
    O_HI := deviceConfig.MotorSpeedMPMOutputHigh
);

// Calculate the actual output torque
OutputTorque := _Scale(
    X := INT_TO_REAL(PDOS.DrvToPLC.torqueActualValue), 
    I_LO := deviceConfig.OutputTorqueInputLow, 
    I_HI := deviceConfig.OutputTorqueInputHigh, 
    O_LO := deviceConfig.OutputTorqueOutputLow, 
    O_HI := deviceConfig.OutputTorqueOutputHigh
);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_Scale" Id="{5a136882-b40c-0a27-157a-89f65724e1c6}">
      <Declaration><![CDATA[METHOD PRIVATE _Scale : REAL
VAR_INPUT
	
	X : REAL;
	I_LO : REAL;
	I_HI : REAL;
	O_LO : REAL;
	O_HI : REAL;
	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF I_LO = I_HI THEN
	_Scale := O_LO;
ELSE
	_Scale := (O_HI - O_LO) / (I_HI - I_LO) * (LIMIT(I_LO, X, I_HI) - I_LO) + O_LO;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_SetOperationMode" Id="{32c0fe40-3203-422c-96bd-b51cb1464eba}">
      <Declaration><![CDATA[METHOD PRIVATE _SetOperationMode
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE deviceConfig.operationMode OF

    E_C2000_ModeOfOperation.Reserved_0:
        PDOS.PlcToDrv.modesOfOperation := 0;
        ; // Reserved - no action

    E_C2000_ModeOfOperation.ProfilePositionMode:
        PDOS.PlcToDrv.modesOfOperation := 1;
        ; // Profile Position Mode handling

    E_C2000_ModeOfOperation.VelocityMode:
        PDOS.PlcToDrv.modesOfOperation := 2;
        ; // Velocity Mode handling

    E_C2000_ModeOfOperation.Reserved_3:
        PDOS.PlcToDrv.modesOfOperation := 3;
        ; // Reserved - no action

    E_C2000_ModeOfOperation.ProfileTorqueMode:
        PDOS.PlcToDrv.modesOfOperation := 4;
		
        ; // Profile Torque Mode handling

    E_C2000_ModeOfOperation.Reserved_5:
        PDOS.PlcToDrv.modesOfOperation := 5;
        ; // Reserved - no action

    E_C2000_ModeOfOperation.HomingMode:
        PDOS.PlcToDrv.modesOfOperation := 6;
        ; // Homing Mode handling

    E_C2000_ModeOfOperation.Reserved_7:
        PDOS.PlcToDrv.modesOfOperation := 7;
        ; // Reserved - no action

    E_C2000_ModeOfOperation.CyclicSynchronousPositionMode:
        PDOS.PlcToDrv.modesOfOperation := 8;
        ; // Cyclic Synchronous Position Mode handling

    E_C2000_ModeOfOperation.Reserved_9:
        PDOS.PlcToDrv.modesOfOperation := 9;
        ; // Reserved - no action

    E_C2000_ModeOfOperation.CyclicSynchronousTorqueMode:
        PDOS.PlcToDrv.modesOfOperation := 10;
        ; // Cyclic Synchronous Torque Mode handling

ELSE
    PDOS.PlcToDrv.modesOfOperation := 2;
    ; // Fallback: Undefined mode, default to reserved

END_CASE
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_SpeedReference" Id="{ddaa3db5-83d9-0169-2b15-fa83a58fd172}">
      <Declaration><![CDATA[METHOD PRIVATE _SpeedReference
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// --- Update Velocity Target Setpoint (signed INT) ---
PDOS.PlcToDrv.vlTargetVelocity := REAL_TO_INT(_Scale(
    X    := speedSetpoint, 
    I_LO := deviceConfig.speedSetpointInputLow, 
    I_HI := deviceConfig.speedSetpointInputHigh, 
    O_LO := deviceConfig.speedSetpointOutputLow, 
    O_HI := deviceConfig.speedSetpointOutputHigh));

	PDOS.PlcToDrv.maxMotorSpeed := PDOS.PlcToDrv.vlTargetVelocity;
	
	pdoSpeedSet := PDOS.PlcToDrv.vlTargetVelocity;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_StatusWord" Id="{6527e086-361c-017b-3cb1-a9e561509a4c}">
      <Declaration><![CDATA[METHOD PRIVATE _StatusWord
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// --- Map raw statusword bits to structured fields ---------------------------
StatusWord.readyToSwitchOn     := PDOS.DrvToPLC.StatusWord.0;   // Bit 0
StatusWord.switchedOn          := PDOS.DrvToPLC.StatusWord.1;   // Bit 1
StatusWord.operationEnabled    := PDOS.DrvToPLC.StatusWord.2;   // Bit 2
StatusWord.fault               := PDOS.DrvToPLC.StatusWord.3;   // Bit 3
StatusWord.voltageEnabled      := PDOS.DrvToPLC.StatusWord.4;   // Bit 4
StatusWord.quickStop           := PDOS.DrvToPLC.StatusWord.5;   // Bit 5
StatusWord.switchOnDisabled    := PDOS.DrvToPLC.StatusWord.6;   // Bit 6
StatusWord.warning             := PDOS.DrvToPLC.StatusWord.7;   // Bit 7
StatusWord.reserved1           := PDOS.DrvToPLC.StatusWord.8;   // Bit 8 (reserved)
StatusWord.remote              := PDOS.DrvToPLC.StatusWord.9;   // Bit 9
StatusWord.targetReached       := PDOS.DrvToPLC.StatusWord.10;  // Bit 10
StatusWord.internalLimitActive := PDOS.DrvToPLC.StatusWord.11;  // Bit 11]]></ST>
      </Implementation>
    </Method>
    <Method Name="_TorqueReference" Id="{eaf20d95-3d2e-4f54-86a7-aad39944681a}">
      <Declaration><![CDATA[METHOD PRIVATE _TorqueReference
VAR_INPUT
END_VAR

VAR
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[

IF deviceConfig.torqueLimiterEnabled THEN
	
	// --- Update Velocity Target Setpoint (signed INT) ---
	PDOS.PlcToDrv.maxTorque := REAL_TO_UINT(_Scale(
		X    := torqueSetpoint, 
		I_LO := deviceConfig.torqueSetpointInputLow, 
		I_HI := deviceConfig.torqueSetpointInputHigh, 
		O_LO := deviceConfig.torqueSetpointOutputLow, 
		O_HI := deviceConfig.torqueSetpointOutputHigh) + deviceConfig.torqueDif);
		
ELSE
	
	PDOS.PlcToDrv.maxTorque := REAL_TO_UINT (deviceConfig.torqueSetpointOutputHigh);
	
END_IF


]]></ST>
      </Implementation>
    </Method>
