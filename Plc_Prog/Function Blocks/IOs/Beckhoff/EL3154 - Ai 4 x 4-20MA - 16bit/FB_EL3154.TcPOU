      <LineId Id="26" Count="0" />
      <LineId Id="39" Count="7" />
      <LineId Id="38" Count="0" />
      <LineId Id="48" Count="7" />
      <LineId Id="47" Count="0" />
    </LineIds>
    <LineIds Name="FB_EL3154._Scale">
      <LineId Id="1" Count="5" />
    </LineIds>
  </POU>
</TcPlcObject>