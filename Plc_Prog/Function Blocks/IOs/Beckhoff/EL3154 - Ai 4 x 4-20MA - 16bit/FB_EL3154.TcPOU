<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="FB_EL3154" Id="{add00169-e4d3-47bc-be2b-57893243ec52}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_EL3154
VAR_INPUT PERSISTENT

	deviceConfig    : EL3154_DEV_CONFIG; // Configuration settings for the CT121F device
	
END_VAR
VAR_OUTPUT
		
	Channel1  : REAL;
	Channel2  : REAL;
	Channel3  : REAL;
	Channel4  : REAL;

END_VAR
VAR
	    PDOS : EL3154_PDOS; // Process Data Objects for RWPT01D communication
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[
_AnalogInputs();]]></ST>
    </Implementation>
    <Method Name="_AnalogInputs" Id="{9b51a4ea-282d-46fc-9e4c-98f548fbbb02}">
      <Declaration><![CDATA[METHOD PRIVATE _AnalogInputs
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Calculate the actual motor speed
Channel1 := _Scale(
    X := DINT_TO_REAL(PDOS.HwToPLC.Channel1.Value), 
    I_LO := deviceConfig.channel1InputLow, 
    I_HI := deviceConfig.channel1InputHigh, 
    O_LO := deviceConfig.channel1OutputLow, 
    O_HI := deviceConfig.channel1OutputHigh
);

// Calculate the actual motor speed
Channel2 := _Scale(
    X := DINT_TO_REAL(PDOS.HwToPLC.Channel2.Value), 
    I_LO := deviceConfig.channe12InputLow, 
    I_HI := deviceConfig.channe12InputHigh, 
    O_LO := deviceConfig.channe12OutputLow, 
    O_HI := deviceConfig.channe12OutputHigh
);

// Calculate the actual motor speed
Channel3 := _Scale(
    X := DINT_TO_REAL(PDOS.HwToPLC.Channel3.Value), 
    I_LO := deviceConfig.channel3InputLow, 
    I_HI := deviceConfig.channel3InputHigh, 
    O_LO := deviceConfig.channel3OutputLow, 
    O_HI := deviceConfig.channel3OutputHigh
);

// Calculate the actual motor speed
Channel4 := _Scale(
    X := DINT_TO_REAL(PDOS.HwToPLC.Channel4.Value), 
    I_LO := deviceConfig.channel4InputLow, 
    I_HI := deviceConfig.channel4InputHigh, 
    O_LO := deviceConfig.channel4OutputLow, 
    O_HI := deviceConfig.channel4OutputHigh
);]]></ST>
      </Implementation>
    </Method>
    <Method Name="_Scale" Id="{e263175c-d452-41d2-b986-f4af6ff52c99}">
      <Declaration><![CDATA[METHOD PRIVATE _Scale : REAL
VAR_INPUT
	
	X : REAL;
	I_LO : REAL;
	I_HI : REAL;
	O_LO : REAL;
	O_HI : REAL;
	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF I_LO = I_HI THEN
	_Scale := O_LO;
ELSE
	_Scale := (O_HI - O_LO) / (I_HI - I_LO) * (LIMIT(I_LO, X, I_HI) - I_LO) + O_LO;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <LineIds Name="FB_EL3154">
      <LineId Id="3" Count="0" />
      <LineId Id="2" Count="0" />
    </LineIds>
    <LineIds Name="FB_EL3154._AnalogInputs">
      <LineId Id="19" Count="6" />
