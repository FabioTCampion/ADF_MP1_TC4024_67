  <DUT Name="EL3154_DEV_CONFIG" Id="{5393de2e-ab70-4f65-af8c-673afdb8f31e}">
    <Declaration><![CDATA[TYPE EL3154_DEV_CONFIG :
    STRUCT
   
        // Setpoint scaling
       	channel1InputLow        : REAL := 0.0;   // Minimum input value for setpoint		
