        channel1OutputLow       : REAL := 0.0; // Minimum output value for setpoint
        channel1OutputHigh      : REAL := 100.0; // Maximum output value for setpoint

       	channe12InputLow        : REAL := 0.0;   // Minimum input value for setpoint		
        channe12InputHigh       : REAL := 32767.0; // Maximum input value for setpoint
        channe12OutputLow       : REAL := 0.0; // Minimum output value for setpoint
        channe12OutputHigh      : REAL := 100.0; // Maximum output value for setpoint		

       	channel3InputLow        : REAL := 0.0;   // Minimum input value for setpoint		
        channel3InputHigh       : REAL := 32767.0; // Maximum input value for setpoint
        channel3OutputLow       : REAL := 0.0; // Minimum output value for setpoint
        channel3OutputHigh      : REAL := 100.0; // Maximum output value for setpoint		

       	channel4InputLow        : REAL := 0.0;   // Minimum input value for setpoint		
        channel4InputHigh       : REAL := 32767.0; // Maximum input value for setpoint
        channel4OutputLow       : REAL := 0.0; // Minimum output value for setpoint
        channel4OutputHigh      : REAL := 100.0; // Maximum output value for setpoint		

    END_STRUCT
END_TYPE

]]></Declaration>
  </DUT>
