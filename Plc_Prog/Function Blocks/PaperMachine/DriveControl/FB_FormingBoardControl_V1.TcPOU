    <Method Name="_ReferenceGenerator" Id="{d1bebbfa-bfe1-4125-b9cf-abcf61a22a04}">
      <Declaration><![CDATA[// 2) REFERENCE GENERATOR
METHOD _ReferenceGenerator
VAR
    headroomEpsPct      : REAL := 0.20;   // anti-chatter near 100%
    offsetPct           : REAL;
    denom               : REAL;
    maxMasterBySlave    : REAL;
    allowedCapPct       : REAL;
    currMasterPct       : REAL;
    currSlavePct        : REAL;
    targetPct           : REAL;
    cmdSpeedMPM         : REAL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// 1) Select Auto/Manual command (MPM)
IF groupSpeedAutoMan THEN
    cmdSpeedMPM := groupAutoSpeedMPM;
ELSE
    cmdSpeedMPM := groupManualSpeedMPM;
END_IF

// 2) Scale to 0..100% for the drives
targetPct := _Scale(
    X    := cmdSpeedMPM,
    I_LO := 0.0,          I_HI := groupMaxSpeed,
    O_LO := 0.0,          O_HI := 100.0);

// 3) During STOPPING/FAULT we want zero target; in STOPPING we still ramp down
IF state = 5 THEN
    rampTargetPct := 0.0;
ELSE
    rampTargetPct := targetPct;
END_IF

// --- Pre-limit so SLAVE can’t exceed 100% for given gear + offset ---
offsetPct := slaveSpeedOffset * 0.01;
denom     := masterSlaveGearRatio + offsetPct;

// If denom <= 0, fall back to 100% (no additional cap required)
IF denom > 0.0 THEN
    maxMasterBySlave := 100.0 / denom;   // master % that makes slave hit 100%
ELSE
    maxMasterBySlave := 100.0;
END_IF;

// The cap the master target must obey (also respect master’s own 100%)
allowedCapPct := MIN(100.0, maxMasterBySlave);

// Apply cap to upward commands only (don’t block decel)
rampTargetPct := MIN(rampTargetPct, allowedCapPct);

// --- Freeze upward if currently at/near limit (anti-overrun using current refs) ---
currMasterPct := instFB_Gen_SRamp.Y;                          // current master ref (%)
currSlavePct  := LIMIT(0.0, currMasterPct * (masterSlaveGearRatio + offsetPct), 100.0);

IF (currMasterPct >= 100.0 - headroomEpsPct) OR
   (currSlavePct  >= 100.0 - headroomEpsPct) THEN
    // Prevent increasing the target above current value; allow decreases
    rampTargetPct := MIN(rampTargetPct, currMasterPct);
END_IF

// 4) Ramp call (unchanged)
instFB_Gen_SRamp(
    X          := rampTargetPct,
    A_UP       := MAX(0.0, rampRate),
    A_DN       := -MAX(0.0, rampRate),
    VU_MAX     := 1000.0,
    VD_MAX     := -1000.0,
    LIMIT_HIGH := 100.0,
    RST        := rampReset);

IF state = 5 THEN
    instFB_Gen_SRamp.LIMIT_LOW := 0.0;
ELSE
    instFB_Gen_SRamp.LIMIT_LOW := 3.5;
END_IF

// 5) Master reference = ramp Y but also respect the slave-driven cap
masterDriveSpeedRefPct := MIN(instFB_Gen_SRamp.Y, allowedCapPct);

// 6) Slave reference: gear + offset, then clamp 0..100
slaveDriveSpeedRefPct :=
    LIMIT(0.0, masterDriveSpeedRefPct * (masterSlaveGearRatio + offsetPct), 100.0);

// 7) Final safety clamp for master (symmetry) + forward as % to next group
masterDriveSpeedRefPct := LIMIT(0.0, masterDriveSpeedRefPct, 100.0);
nextGroupSpeedRefPct   := masterDriveSpeedRefPct;

// 8) Also forward the next group reference in MPM (easy to replicate elsewhere)
nextGroupSpeedRefMPM := _Scale(
    X    := nextGroupSpeedRefPct,
    I_LO := 0.0,          I_HI := 100.0,
    O_LO := 0.0,          O_HI := groupMaxSpeed);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_Scale" Id="{70e52522-893d-4230-ac46-b736c1d79a1d}">
      <Declaration><![CDATA[METHOD PRIVATE _Scale : REAL
VAR_INPUT
    X    : REAL;
    I_LO : REAL;
    I_HI : REAL;
    O_LO : REAL;
    O_HI : REAL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF I_LO = I_HI THEN
	_Scale := O_LO;
ELSE
	_Scale := (O_HI - O_LO) / (I_HI - I_LO) * (LIMIT(I_LO, X, I_HI) - I_LO) + O_LO;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_SlaveTorquePID" Id="{d2f2c034-a009-466c-a7c6-a830587846dc}">
      <Declaration><![CDATA[// 6) OPTIONAL: SLAVE TORQUE PID TRACKING (new)
METHOD _SlaveTorquePID
VAR_INPUT
    enablePID : BOOL := TRUE;   // TRUE=PID active, FALSE=hold/track current output
    Kp        : REAL := 0.8;    // proportional gain (tune as needed)
    Tn        : REAL := 1.5;    // integral time [s]
    Tv        : REAL := 0.0;    // derivative time [s]
END_VAR
VAR
    masterFilt : REAL;
    slaveFilt  : REAL;
    sp         : REAL;  // setpoint (master)
    pv         : REAL;  // process value (slave)
    y          : REAL;  // PID output (pre-clamp)
    e          : REAL;  // SET - ACT (diagnostic)
    limMin     : REAL;
    limMax     : REAL;
END_VAR
VAR_STAT
    pid        : CTRL_PID;  // PID instance (retained)
    fMaster    : FT_PT1;    // PT1 for master torque
    fSlave     : FT_PT1;    // PT1 for slave torque
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// 1) Filter master & slave torques (reuse existing time constant)
fMaster(in := masterTorqueFeedback, T := torqueFilterTime, K := 1.0, out => masterFilt);
fSlave (in := slaveTorqueFeedback , T := torqueFilterTime, K := 1.0, out => slaveFilt);

// 2) Build setpoint and PV
sp := masterFilt + slaveTorqueOfsset;   // follow master + configured trim
pv := slaveFilt;

// 3) Limits from existing configuration
limMin := torqueLimitMinPct;
limMax := torqueLimitMaxPct;

// 4) PID with bumpless transfer (manual input tracks current output when disabled)
pid(
    ACT := pv,                      // process value (slave torque)
    SET := sp,                      // setpoint (master torque)
    MAN := NOT enablePID,           // MAN=TRUE => manual/track
    M_I := slaveDriveTorqueLimit,   // track current output for bumpless re-enable
    RST := FALSE,                   // external reset (unused)
    KP  := Kp,
    TN  := Tn,
    TV  := Tv,
    LL  := limMin,
    LH  := limMax,
    Y   => y,
    DIFF=> e,
    LIM =>                          // unused
);

// 5) Clamp and publish
slaveDriveTorqueLimit := LIMIT(limMin, y, limMax);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_SpeedDifferenceCheck" Id="{04e52e61-860d-4025-9001-97f886bc892a}">
      <Declaration><![CDATA[METHOD PRIVATE _SpeedDifferenceCheck
VAR
    diff : REAL;
END_VAR

]]></Declaration>
      <Implementation>
        <ST><![CDATA[// 1) Absolute difference Master-Slave
diff := ABS(masterSpeedMPMFilteredDisplay - slaveSpeedMPMFilteredDisplay);
currentSpeedDifence := diff;

// 2) If beyond limit -> stop group (with a small delay)
IF diff > speedDiferenceLimit THEN
    instTONSpeedDifDelay.IN := TRUE;
    instTONSpeedDifDelay.PT := T#2S;

    IF instTONSpeedDifDelay.Q THEN
        state := 10;                  // Fault
        deviceState := 'FAULT: Speed difference exceeded';
    END_IF
ELSE
    instTONSpeedDifDelay.IN := FALSE;
END_IF

instTONSpeedDifDelay();
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_StateDisplay" Id="{d53a5fea-f9d1-4630-b78f-0baae473f501}">
      <Declaration><![CDATA[METHOD _StateDisplay
VAR_INPUT
END_VAR

// ──────────────────────────────────────────────────────────────────────────────
// _StateDisplay
// Maps the internal machine "state" to a compact HMI status code and derives
// per-drive motor status codes from VFD signals.
//
// statusCode / masterStatusCode / slaveStatusCode legend:
//   0 = Idle, 1 = Starting, 2 = Running, 3 = Fault
//
// Machine "state" groups:
//   0 = IDLE, 1 = ENABLE, 2 = WAIT_EN, 3 = RAMP_EN, 4 = RUN, 5 = STOPPING, 10 = FAULT
// Priority rule (for motors): Fault > Running > Starting > Idle
// ──────────────────────────────────────────────────────────────────────────────
VAR CONSTANT
    STATUS_IDLE     : INT := 0;
//    STATUS_STARTING : INT := 1;
    STATUS_RUNNING  : INT := 1;
    STATUS_FAULT    : INT := 2;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
// ─────────────── Group machine states into a single HMI statusCode ───────────
CASE state OF
    10: // FAULT
        statusCode := STATUS_FAULT;

    4:  // RUN
        statusCode := STATUS_RUNNING;

    1, 2, 3: // ENABLE / WAIT_EN / RAMP_EN
//        statusCode := STATUS_STARTING;

    ELSE // IDLE, STOPPING, or any other unlisted state
        statusCode := STATUS_IDLE;
END_CASE;

// ─────────────── Helper pattern for per-drive status (inline) ────────────────
// Evaluation order enforces priority: Fault > Running > Starting > Idle

// Master drive
IF formingBoardTractionRollVfdFaultFeedback THEN
    masterStatusCode := STATUS_FAULT;
ELSIF formingBoardTractionRollVfdRunFeedback THEN
    masterStatusCode := STATUS_RUNNING;
ELSE
    masterStatusCode := STATUS_IDLE;
END_IF;

// Slave drive
IF formingBoardSuctionVfdFaultFeedback THEN
    slaveStatusCode := STATUS_FAULT;
ELSIF formingBoardSuctionVfdRunFeedback THEN
    slaveStatusCode := STATUS_RUNNING;
ELSE
    slaveStatusCode := STATUS_IDLE;
END_IF;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_TorqueReference" Id="{1898f17f-1d1c-48e9-86d0-81f7e5611d7a}">
      <Declaration><![CDATA[METHOD _TorqueReference
VAR
    rawTorque     : REAL;
    filtTorque    : REAL;
    torqueCmd     : REAL;
    limitedTorque : REAL;
    clamped       : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// 1) Read master torque (keep units consistent with your limits)
rawTorque := masterTorqueFeedback;

// 2) Low-pass filter (OSCAT PT1)
instsFT_PT1TorqueFilter(
    in  := rawTorque,
    T   := torqueFilterTime,   // time constant in seconds (e.g., 0.25)
    K   := 0.8,                // unity gain
    out => filtTorque
);

// 3) Deadband cleanup
IF ABS(filtTorque) < torqueDeadbandPct THEN
    filtTorque := 0.0;
END_IF

// 4) Apply offset between master and slave
torqueCmd := filtTorque + slaveTorqueOfsset;

// 5) Clamp to limits
limitedTorque := LIMIT(torqueLimitMinPct, torqueCmd, torqueLimitMaxPct);
clamped       := (limitedTorque <> torqueCmd);

// 6) Output
slaveDriveTorqueLimit := limitedTorque;


//slaveDriveTorqueLimit := LIMIT(torqueLimitMinPct, masterTorqueFeedback, torqueLimitMaxPct);]]></ST>
      </Implementation>
    </Method>
