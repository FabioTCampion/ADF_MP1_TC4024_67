<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="FB_FormingBoardControl_V1" Id="{0341cbdf-b8a3-4b8d-9801-cb7e35cafbf7}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_FormingBoardControl_V1
VAR_INPUT
    // ── Group / Interlocks ───────────────────────────────────────────────────────
    startGroup                   : BOOL;   // Start command (pulse / rising edge)
    stopGroup                    : BOOL;   // Stop command  (pressed / level)
    groupReset                   : BOOL;   // Group fault Reset (Comando reset falhas do grupo)
    groupFastStop           : BOOL;  // EN: Reset group faults / PT: Reset de falhas do grupo

    // ── VFD per-drive status inputs ─────────────────────────────────────────────
    formingBoardTractionRollFault               : BOOL;   // VFD ready/healthy (master)
	formingBoardTractionRollCoolingFault  : BOOL;   // VFD ready/healthy (master)
    formingBoardTractionRollVfdRunFeedback         : BOOL;   // VFD RUN feedback  (master)
    formingBoardTractionRollVfdFaultFeedback       : BOOL;   // VFD fault         (master)
   
	formingBoardSuctionRollFault                : BOOL;   // VFD ready/healthy (slave)
	formingBoardSuctionRollCoolingFault		: BOOL;   // VFD ready/healthy (slave)	
	
    formingBoardSuctionVfdRunFeedback          : BOOL;   // VFD RUN feedback  (slave)
    formingBoardSuctionVfdFaultFeedback        : BOOL;   // VFD fault         (slave)

	
	paperPresenceSensor				: BOOL;
	
    // ── Speed Setpoints ─────────────────────────────────────────────────────────
    groupAutoSpeedMPM            : REAL;   // Auto speed setpoint [m/min]
    groupMaxSpeed                : REAL := 600.0; // Max allowed line speed [m/min]

    // ── Auto / Manual ───────────────────────────────────────────────────────────
    groupSpeedAutoMan            : BOOL;   // 0=Manual / 1=Auto
    groupManualSpeedMPM          : REAL := 50.0;  // Manual speed [m/min]

    // ── Feedbacks ───────────────────────────────────────────────────────────────
    masterTorqueFeedback         : REAL;   // [% or Nm]
    slaveTorqueFeedback          : REAL;   // [% or Nm]
    masterSpeedFeedback          : REAL;   // [m/min or %] — be consistent
    slaveSpeedFeedback           : REAL;   // [m/min or %] — be consistent

    // ── Ratio & Offsets ─────────────────────────────────────────────────────────
    masterSlaveGearRatio		: REAL := 1.0;   // Slave/Master speed ratio
// 	interGroupGearRatio			: REAL := 1.0;   // Speed diference btween groups
	
    slaveTorqueOfsset            : REAL := 0.0;   // (typo kept) torque trim [%/Nm]
    slaveSpeedOffset             : REAL := 10;    // Offset as % of master speed (+5 => +5%)

    // ── Torque control parameters ───────────────────────────────────────────────
    torqueLimitMinPct            : REAL := 5.0;   // Min torque [%]  (allow negative if regen)
    torqueLimitMaxPct            : REAL := 100.0; // Max torque [%]
    torqueDeadbandPct            : REAL := 1.0;   // |torque| below => 0 (noise cleanup)
	
    torqueFilterTime             : TIME := T#1MS;
    displayFilterTime             : TIME := T#20MS;	

    // ── Dynamics (for ramp block) ───────────────────────────────────────────────
    rampRate                     : REAL := 0.01;  // Ref accel mag in %/s (A_UP=+rampRate, A_DN=-rampRate)

    // ── Speed difference limit ──────────────────────────────────────────────────
    speedDiferenceLimit          : REAL := 5.0;
	
	
	
	
	//Headbox inputs
	
	//==============================================================
	// FORMING BOARD — WIRE EDGE OVERRUN SENSORS
	//==============================================================
	formingBoardWireOverrunOperatorSideSensor : BOOL;  // TRUE when wire overruns on operator side
	formingBoardWireOverrunDriveSideSensor    : BOOL;  // TRUE when wire overruns on drive/motor side	

	//==============================================================
	// HEADBOX LIPS OPENING CONTROL — VARIABLES
	//==============================================================
	
	// Position feedback and physical limits [mm]
	headboxLipsPositionFeedback_mm     : REAL;          // Actual lips opening [mm]
	headboxLipsMinOpening_mm           : REAL := 0.0;   // Minimum allowed opening [mm]
	headboxLipsMaxOpening_mm           : REAL := 25.0;  // Maximum allowed opening [mm]
	
	// Limit sensors (digital inputs)
	headboxLipsLimitFullyOpen          : BOOL;          // TRUE when fully open (max) limit sensor active
	headboxLipsLimitFullyClosed        : BOOL;          // TRUE when fully closed (min) limit sensor active
	
	// Manual jog commands (for manual mode)
	headboxLipsManualOpenCmd           : BOOL;          // Jog open while pressed
	headboxLipsManualCloseCmd          : BOOL;          // Jog close while pressed
	
	// Automatic positioning (for auto mode)
	headboxLipsTargetSetpoint_mm       : REAL;          // Desired lips opening [mm]
	headboxLipsAutoAdjustCmd           : BOOL;          // Pulse to start auto adjustment
	
		
	formingBoardRollUpCmd        : BOOL;  // Command to move forming board UP (active-high)
	formingBoardRollDownCmd      : BOOL;  // Command to move forming board DOWN (active-high)
	formingBoardRollLimitUpSensor    : BOOL;  // TRUE when upper limit is reached (prevents further UP)
	formingBoardRollLimitDownSensor  : BOOL;  // TRUE when lower limit is reached (prevents further DOWN)
	formingBoardRollUpDownMotorFault            : BOOL;  // TRUE = fault present → disables all movement	
	
	formingBoardStretchCmd           : BOOL;  // Jog command to stretch (increase tension)
	formingBoardUnstretchCmd         : BOOL;  // Jog command to unstretch (decrease tension)
	formingBoardLimitStretchSensor   : BOOL;  // TRUE when maximum stretch limit is reached
	formingBoardLimitUnstretchSensor : BOOL;  // TRUE when minimum stretch limit is reached
	formingBoardStretchMotorFault         : BOOL;  // Fault interlock for stretch unit
	
		
END_VAR

VAR_OUTPUT
    deviceState                  : STRING;
    groupFault                   : BOOL;   // Fault present (Falha do grupo)

    // ── Drive References (0..100%) ──────────────────────────────────────────────
    masterDriveSpeedRefPct       : REAL;   // Master reference [%]
    slaveDriveSpeedRefPct        : REAL;   // Slave  reference [%]
	nextGroupSpeedRefPct		 : REAL;   // Next group reference [%]
	nextGroupSpeedRefMPM		 : REAL;   // Next group reference [Meters per minute]
	
    // ── Torque limit to slave (from master torque path / or PID) ───────────────
    slaveDriveTorqueLimit        : REAL;   // [% or Nm]

    // ── Drive Commands ──────────────────────────────────────────────────────────
    masterDriveEnable            : BOOL;
    slaveDriveEnable             : BOOL;
    masterDriveReset             : BOOL;
    slaveDriveReset              : BOOL;

    // ── Diagnostics ─────────────────────────────────────────────────────────────
    currentSpeedDifence          : REAL;

    // ── Group status & HMI displays ────────────────────────────────────────────
    statusCode                   	: INT;    // 0=Idle, 1=Starting, 2=Running, 3=Fault (group)
	
    masterSpeedMPMFilteredDisplay   : REAL;   // Filtered master speed [m/min]
    slaveSpeedMPMFilteredDisplay    : REAL;   // Filtered slave  speed [m/min]
	
    masterTorqueFilteredDisplay  	: REAL;   // Master torque (raw)  [% or Nm]
    slaveTorqueFilteredDisplay   	: REAL;   // Slave torque (filtered) [% or Nm]

    // ── NEW: per-drive motor status codes ───────────────────────────────────────
    masterStatusCode             : INT;    // 0=Idle, 1=Starting, 2=Running, 3=Fault
    slaveStatusCode              : INT;    // 0=Idle, 1=Starting, 2=Running, 3=Fault
	
	//==============================================================
	// HEADBOX LIPS OPENING CONTROL — OUTPUTS
	//==============================================================
	
	// Drive outputs (modulated by PWM in automatic mode)
	headboxLipsOpenCmd                : BOOL;  // Output to open lips (PWM-modulated in Auto mode)
	headboxLipsCloseCmd               : BOOL;  // Output to close lips (PWM-modulated in Auto mode)
	headboxLipsPosition_mm       		  : REAL;  // Target − Feedback error [mm]
	
	//==============================================================
	// FORMING BOARD — ROLL DRIVE OUTPUTS
	//==============================================================
	formingBoardRollUp       : BOOL;  // Output to drive the forming board UP
	formingBoardRollDown     : BOOL;  // Output to drive the forming board DOWN
	
	//==============================================================
	// FORMING BOARD — STRETCH DRIVE OUTPUTS
	//==============================================================
	formingBoardStretch      : BOOL;  // Output to stretch (increase tension)
	formingBoardUnstretch    : BOOL;  // Output to unstretch (decrease tension)
		

	hmiAlarms 				: PaperMachine_TypeHmiAlarms; 	

END_VAR

VAR
    // ── Internals / Ramps ───────────────────────────────────────────────────────
    rampTargetPct                : REAL;   // 0..100% target into ramp
    instFB_Gen_SRamp             : FB_Gen_SRamp; // Your ramp FB

    // ── State & Edges ───────────────────────────────────────────────────────────
    state                        : INT;    // 0=IDLE,1=ENABLE,2=WAIT_EN,3=RAMP_EN,4=RUN,5=STOPPING,10=FAULT
    startGroupOld                : BOOL;
    stopGroupOld                 : BOOL;
    rStart                       : BOOL;
    rStop                        : BOOL;

    // ── Timers & thresholds ─────────────────────────────────────────────────────
    instTONEnableWait            : TON;
    instTONStopWait              : TON;
    enableTimeout                : TIME := T#5s;  // Wait for op-enable
    stopTimeout                  : TIME := T#8s;  // Max wait to speed≈0
    speedZeroThresholdPct        : REAL := 4.00;  // Consider stopped if |speed| ≤ this
    epsRefPct                    : REAL := 0.05;  // Small epsilon for ref≈0

    // ── Ramp control ────────────────────────────────────────────────────────────
    rampReset                    : BOOL;   // Resets ramp (sets Y/V to 0 in your FB)

    // ── Filter state used by _TorqueReference ───────────────────────────────────
    torqueFiltY                  : REAL;   // last filtered torque
    torqueFiltInit               : BOOL;   // init flag (bumpless start)
    instsFT_PT1TorqueFilter      : FT_PT1;

    // ── Speed difference supervision ────────────────────────────────────────────
    instTONSpeedDifDelay         : TON;

    // ── HMI-only PT1 filters ───────────────────────────────────────────────────
    instPT1_MasterSpeedDisplay          : FT_PT1;
    instPT1_SlaveSpeedDisplay           : FT_PT1;
	
    instPT1_MasterTorqueDisplay  		: FT_PT1;
    instPT1_SlaveTorqueDisplay   		: FT_PT1;
	
	instFB_HeadboxLipsPWMControl		: FB_HeadboxLipsPWMControl;	
	
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[// ─────────────────────────────────────────────────────────────────────────────
// MAIN CALL SEQUENCE
// ─────────────────────────────────────────────────────────────────────────────
_FeedbackDisplay();
_GroupControl();          // 1) State machine: edges, enables, stop modes
_ReferenceGenerator();    // 2) Build master/slave references with ramp
_TorqueReference();       // 3) Legacy torque transfer (kept)
_StateDisplay();

_SpeedDifferenceCheck();  // 4) Speed difference monitor & trip
_headboxLipsPosition();

_auxiliaryControls();
_alarmsDisplay();]]></ST>
    </Implementation>
    <Method Name="_alarmsDisplay" Id="{0461d554-8be0-4155-a22f-684dbe18fcea}">
      <Declaration><![CDATA[METHOD _alarmsDisplay
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//==============================================================
// FAULT EVALUATION — PER CONDITION (flags only; no global set)
//==============================================================

//----------------------------
// FORMING BOARD DRIVES
//----------------------------
hmiAlarms.formingBoardRollDriveFaultAlarm    := formingBoardRollUpDownMotorFault;
hmiAlarms.formingBoardStretchDriveFaultAlarm := formingBoardStretchMotorFault;

//----------------------------
// FORMING BOARD AUXILIARY MOTORS
//----------------------------
hmiAlarms.formingBoardSuctionRollFaultAlarm         := formingBoardSuctionRollFault;
hmiAlarms.formingBoardSuctionRollCoolingFaultAlarm  := formingBoardSuctionRollCoolingFault;
hmiAlarms.formingBoardTractionRollFaultAlarm        := formingBoardTractionRollFault;
hmiAlarms.formingBoardTractionRollCoolingFaultAlarm := formingBoardTractionRollCoolingFault;

//----------------------------
// FORMING BOARD WIRE OVERRUN
//----------------------------
hmiAlarms.formingBoardWireOverrunOperatorSideAlarm := formingBoardWireOverrunOperatorSideSensor;
hmiAlarms.formingBoardWireOverrunDriveSideAlarm    := formingBoardWireOverrunDriveSideSensor;

//----------------------------
// FORMING BOARD GROUP FAULT STATUS
//----------------------------
groupFault :=
    hmiAlarms.formingBoardRollDriveFaultAlarm OR
    hmiAlarms.formingBoardStretchDriveFaultAlarm OR
    hmiAlarms.formingBoardSuctionRollFaultAlarm OR
    hmiAlarms.formingBoardSuctionRollCoolingFaultAlarm OR
    hmiAlarms.formingBoardTractionRollFaultAlarm OR
    hmiAlarms.formingBoardTractionRollCoolingFaultAlarm OR
    hmiAlarms.formingBoardWireOverrunOperatorSideAlarm OR
    hmiAlarms.formingBoardWireOverrunDriveSideAlarm;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_auxiliaryControls" Id="{a22de1c9-6b9a-4972-be03-0a4d0f8183e9}">
      <Declaration><![CDATA[METHOD _auxiliaryControls
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//============================
// FORMING BOARD ROLL UP/DOWN
//============================
IF NOT formingBoardRollUpDownMotorFault THEN
    IF formingBoardRollUpCmd AND NOT formingBoardRollDownCmd AND NOT formingBoardRollLimitUpSensor THEN
        formingBoardRollUp := TRUE;
    ELSE
        formingBoardRollUp := FALSE;
    END_IF;

    IF formingBoardRollDownCmd AND NOT formingBoardRollUpCmd AND NOT formingBoardRollLimitDownSensor THEN
        formingBoardRollDown := TRUE;
    ELSE
        formingBoardRollDown := FALSE;
    END_IF;
ELSE
    formingBoardRollUp := FALSE;
    formingBoardRollDown := FALSE;
END_IF;


//============================
// FORMING BOARD STRETCH/UNSTRETCH
//============================
IF NOT formingBoardStretchMotorFault THEN
    IF formingBoardStretchCmd AND NOT formingBoardUnstretchCmd AND NOT formingBoardLimitStretchSensor THEN
        formingBoardStretch := TRUE;
    ELSE
        formingBoardStretch := FALSE;
    END_IF;

    IF formingBoardUnstretchCmd AND NOT formingBoardStretchCmd AND NOT formingBoardLimitUnstretchSensor THEN
        formingBoardUnstretch := TRUE;
    ELSE
        formingBoardUnstretch := FALSE;
    END_IF;
ELSE
    formingBoardStretch := FALSE;
    formingBoardUnstretch := FALSE;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_FeedbackDisplay" Id="{9787b19e-cb2a-4ad6-b3b8-527a44a0dd75}">
      <Declaration><![CDATA[METHOD _FeedbackDisplay
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// 5) HMI DISPLAY SIGNALS (filtered speeds/torques + GROUP status)
instPT1_MasterSpeedDisplay(in := masterSpeedFeedback, T := displayFilterTime, K := 1.0, out => masterSpeedMPMFilteredDisplay);
instPT1_SlaveSpeedDisplay (in := slaveSpeedFeedback , T := displayFilterTime, K := 1.0, out => slaveSpeedMPMFilteredDisplay);

instPT1_MasterTorqueDisplay(in := masterTorqueFeedback, T := displayFilterTime, K := 1.0, out => masterTorqueFilteredDisplay);
instPT1_SlaveTorqueDisplay (in := slaveTorqueFeedback , T := displayFilterTime, K := 1.0, out => slaveTorqueFilteredDisplay);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_GroupControl" Id="{ffb736eb-8f73-4dad-91a7-f4ecebade366}">
      <Declaration><![CDATA[// ============================== Methods ==============================
// 1) GROUP CONTROL
METHOD _GroupControl
VAR_INPUT
END_VAR
VAR
    speedsNearZero : BOOL;
    refNearZero    : BOOL;
    bothOpEnabled  : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Edges
rStart := startGroup AND NOT startGroupOld;     // Start on pulse
rStop  := stopGroup  AND NOT stopGroupOld;      // Stop also has an edge
startGroupOld := startGroup;
stopGroupOld  := stopGroup;

// Feedback conditions (unit matches your % references)
speedsNearZero :=
    (ABS(masterSpeedFeedback) <= speedZeroThresholdPct) AND
    (ABS(slaveSpeedFeedback)  <= speedZeroThresholdPct);

// Also consider the reference near zero (backup)
refNearZero := ABS(masterDriveSpeedRefPct) <= epsRefPct;

// Use the original "operation enabled" for RUN readiness
bothOpEnabled := formingBoardTractionRollFault AND formingBoardSuctionRollFault;

CASE state OF
    0: // IDLE
        deviceState := 'IDLE';
        rampReset := TRUE;
        IF rStart AND NOT groupFault THEN
            state := 1;
        END_IF

    1: // ENABLE DRIVES
        deviceState := 'ENABLE_DRIVES';
        masterDriveEnable := TRUE;
        slaveDriveEnable  := TRUE;
        rampReset         := TRUE;

        instTONEnableWait(IN := TRUE, PT := enableTimeout);
        IF stopGroup THEN
            instTONEnableWait(IN := FALSE);
            state := 5;
        ELSE
            state := 2;
        END_IF

    2: // WAIT ENABLE FEEDBACK
        deviceState := 'WAIT_ENABLE_FEEDBACK';
        masterDriveEnable := TRUE;
        slaveDriveEnable  := TRUE;
        rampReset         := TRUE;

        instTONEnableWait(IN := TRUE, PT := enableTimeout);

        IF groupFault THEN
            instTONEnableWait(IN := FALSE);
            state := 10;
        ELSIF rStop OR stopGroup THEN
            instTONEnableWait(IN := FALSE);
            state := 5;
        ELSIF bothOpEnabled THEN
            instTONEnableWait(IN := FALSE);
            state := 3;
        ELSIF instTONEnableWait.Q THEN
            instTONEnableWait(IN := FALSE);
            state := 10; // fault: no enable feedback
        END_IF

    3: // RAMP ENABLE (single-cycle gate)
        deviceState := 'RAMP_ENABLE';
        masterDriveEnable := TRUE;
        slaveDriveEnable  := TRUE;
        rampReset         := FALSE; // release ramp now
        IF stopGroup THEN
            state := 5;
        ELSE
            state := 4;
        END_IF

    4: // RUN
        deviceState := SEL(groupSpeedAutoMan,'RUN (Manual)', 'RUN (Auto)');
        masterDriveEnable := TRUE;
        slaveDriveEnable  := TRUE;
        rampReset         := FALSE;

        IF groupFault THEN
            state := 10;
        ELSIF rStop OR stopGroup THEN
            state := 5;
        END_IF

    5: // STOPPING (controlled)
        deviceState := 'STOPPING';
        masterDriveEnable := TRUE;    // keep enabled during decel
        slaveDriveEnable  := TRUE;
        rampReset         := FALSE;   // ramp down references
        // instTONStopWait(IN := TRUE, PT := stopTimeout);  // optional timeout

        // Disable when speed≈0 AND reference≈0
        IF groupFault THEN
            instTONStopWait(IN := FALSE);
            state := 10;

        ELSIF speedsNearZero AND refNearZero THEN
            masterDriveEnable := FALSE;
            slaveDriveEnable  := FALSE;
            instTONStopWait(IN := FALSE);
            state := 0;

        ELSIF instTONStopWait.Q THEN
            masterDriveEnable := FALSE;
            slaveDriveEnable  := FALSE;
            instTONStopWait(IN := FALSE);
            state := 10;
        END_IF

    10: // FAULT
        deviceState := 'FAULT';
        rampReset         := TRUE;    // force ramp outputs to zero
        masterDriveEnable := FALSE;
        slaveDriveEnable  := FALSE;

        // Clear fault when fault disappears and start is low
        IF (NOT groupFault) AND (NOT startGroup) THEN
            state := 0;
        END_IF
END_CASE;]]></ST>
      </Implementation>
    </Method>
