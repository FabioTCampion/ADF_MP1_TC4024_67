<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="FB_DryingSectionDriveControl_V3" Id="{cd314c72-f2d9-4d93-8194-11eb1eec5165}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_DryingSectionDriveControl_V3
VAR_INPUT

    //==============================================================
    // GROUP INTERLOCKS & COMMANDS
    //==============================================================
    startGroup              : BOOL;  // EN: Start command (pulse) / PT: Comando de partida (pulso)
    stopGroup               : BOOL;  // EN: Stop command (level) / PT: Comando de parada (nível)

    groupFastStop           : BOOL;  // EN: Reset group faults / PT: Reset de falhas do grupo
	
    groupReset              : BOOL;  // EN: Reset group faults / PT: Reset de falhas do grupo

	
	groupNumber				: INT;
    //==============================================================
    // SPEED OFFSET / MANUAL ADJUSTMENTS
    //==============================================================
    grouSpeedDifIncCmd      : BOOL;  // EN: Lamp or indication – speed offset increasing / PT: Lâmpada ou indicação – offset de velocidade aumentando
    grouSpeedDifDecCmd      : BOOL;  // EN: Lamp or indication – speed offset decreasing / PT: Lâmpada ou indicação – offset de velocidade reduzindo
    groupRecoverSpeedCmd    : BOOL;  // EN: Recover nominal speed while TRUE / PT: Recuperar velocidade nominal enquanto TRUE

    //==============================================================
    // DRIVE STATUS INPUTS — UPPER GROUP
    //==============================================================
    upperMasterReady        : BOOL;  // EN: Upper master ready (no trip) / PT: Mestre superior pronto (sem falha)
    upperSlave1Ready        : BOOL;  // EN: Upper slave 1 ready / PT: Escravo 1 superior pronto

    //==============================================================
    // DRIVE STATUS INPUTS — LOWER GROUP
    //==============================================================
    lowerMasterReady        : BOOL;  // EN: Lower master ready (no trip) / PT: Mestre inferior pronto (sem falha)
    lowerSlave1Ready        : BOOL;  // EN: Lower slave 1 ready / PT: Escravo 1 inferior pronto

    //==============================================================
    // SPEED SETPOINTS & MODE SELECTION
    //==============================================================
    groupAutoSpeedMPM       : REAL;        // EN: Automatic mode speed [m/min] / PT: Velocidade em modo automático [m/min]
    groupManualSpeedMPM     : REAL := 50.0;// EN: Manual mode speed [m/min] / PT: Velocidade em modo manual [m/min]
    groupSpeedAutoMan       : BOOL;        // EN: Speed mode (0=Manual, 1=Auto) / PT: Modo de velocidade (0=Manual, 1=Automático)

    //==============================================================
    // SPEED & TORQUE FEEDBACKS — UPPER GROUP
    //==============================================================
    upperMasterSpeedFeedback    : REAL;  // [m/min or %]
    upperMasterTorqueFeedback   : REAL;  // [% or Nm]
    upperSlave1SpeedFeedback    : REAL;
    upperSlave1TorqueFeedback   : REAL;

    //==============================================================
    // SPEED & TORQUE FEEDBACKS — LOWER GROUP
    //==============================================================
    lowerMasterSpeedFeedback    : REAL;
    lowerMasterTorqueFeedback   : REAL;
    lowerSlave1SpeedFeedback    : REAL;
    lowerSlave1TorqueFeedback   : REAL;

    //==============================================================
    // COOLING MOTOR FAULT INPUTS
    //==============================================================
    upperMasterCoolingMotorFault : BOOL;  // EN: Upper master cooling motor fault / PT: Falha no motor de ventilação do mestre superior
    upperSlave1CoolingMotorFault : BOOL;  // EN: Upper slave 1 cooling motor fault / PT: Falha no motor de ventilação do escravo 1 superior
    lowerMasterCoolingMotorFault : BOOL;  // EN: Lower master cooling motor fault / PT: Falha no motor de ventilação do mestre inferior
    lowerSlave1CoolingMotorFault : BOOL;  // EN: Lower slave 1 cooling motor fault / PT: Falha no motor de ventilação do escravo 1 inferior

    //==============================================================
    // FABRIC / WIRE STRETCHER ACTUATORS
    //==============================================================
    upperDryingSectionFabricStretchCmd     : BOOL;  // EN: Command to stretch upper fabric / PT: Comando para esticar a tela superior
    upperDryingSectionFabricUnstretchCmd   : BOOL;  // EN: Command to loosen upper fabric / PT: Comando para afrouxar a tela superior
	upperDryingSectionFabricStretchLimMax	: BOOL;
	upperDryingSectionFabricStretchLimMin	: BOOL;
    upperDryingSectionFabricStretcherMotorFault : BOOL;  // EN: Upper stretcher motor fault / PT: Falha no motor de estiramento superior


    lowerDryingSectionFabricStretchCmd     : BOOL;  // EN: Command to stretch lower fabric / PT: Comando para esticar a tela inferior
    lowerDryingSectionFabricUnstretchCmd   : BOOL;  // EN: Command to loosen lower fabric / PT: Comando para afrouxar a tela inferior
	lowerDryingSectionFabricStretchLimMax	: BOOL;
	lowerDryingSectionFabricStretchLimMin	: BOOL;   
 	lowerDryingSectionFabricStretcherMotorFault : BOOL;  // EN: Lower stretcher motor fault / PT: Falha no motor de estiramento inferior

    //==============================================================
    // FABRIC / WIRE OVERRUN SENSORS
    //==============================================================
    upperDryingSectionFabricOverrunOperatorSideSensor : BOOL; // EN: Upper fabric overrun sensor (operator side) / PT: Sensor de sobrecurso da tela superior (lado operador)
    upperDryingSectionFabricOverrunDriveSideSensor    : BOOL; // EN: Upper fabric overrun sensor (drive side) / PT: Sensor de sobrecurso da tela superior (lado acionamento)
    lowerDryingSectionFabricOverrunOperatorSideSensor : BOOL; // EN: Lower fabric overrun sensor (operator side) / PT: Sensor de sobrecurso da tela inferior (lado operador)
    lowerDryingSectionFabricOverrunDriveSideSensor    : BOOL; // EN: Lower fabric overrun sensor (drive side) / PT: Sensor de sobrecurso da tela inferior (lado acionamento)

    //==============================================================
    // PICK-UP ROLL POSITIONER
    //==============================================================
    pickUpRollPosCmdFwd       : BOOL;  // EN: Command forward / PT: Avanço do rolo pick-up
    pickUpRollPosCmdRev       : BOOL;  // EN: Command reverse / PT: Recuo do rolo pick-up
    pickUpRollPosLimitFwd     : BOOL;  // EN: Forward limit switch / PT: Fim de curso frontal
    pickUpRollPosLimitRev     : BOOL;  // EN: Reverse limit switch / PT: Fim de curso traseiro
    pickUpRollPosFault        : BOOL;  // EN: Positioner fault / PT: Falha no posicionador

    //==============================================================
    // SCRAPER OSCILLATORS
    //==============================================================
    babyDryerScraperOscCmd     : BOOL;  // EN: Command to start Baby Dryer scraper oscillator / PT: Comando para iniciar oscilador do Baby Dryer
    babyDryerScraperOscFault   : BOOL;  // EN: Baby Dryer oscillator fault / PT: Falha no oscilador do Baby Dryer
    babyDryerScraperOscRunning : BOOL;  // EN: Baby Dryer oscillator running / PT: Oscilador do Baby Dryer em operação

    upperGroupScraperOscCmd     : BOOL;  // EN: Upper group scraper oscillator command / PT: Comando de oscilação da raspa do grupo superior
    upperGroupScraperOscFault   : BOOL;  // EN: Upper group oscillator fault / PT: Falha no oscilador do grupo superior
    upperGroupScraperOscRunning : BOOL;  // EN: Upper group oscillator running / PT: Oscilador do grupo superior em operação

    lowerGroupScraperOscCmd     : BOOL;  // EN: Lower group scraper oscillator command / PT: Comando de oscilação da raspa do grupo inferior
    lowerGroupScraperOscFault   : BOOL;  // EN: Lower group oscillator fault / PT: Falha no oscilador do grupo inferior
    lowerGroupScraperOscRunning : BOOL;  // EN: Lower group oscillator running / PT: Oscilador do grupo inferior em operação

    //==============================================================
    // STEAM PRESSURE CONTROL (PID)
    //==============================================================
    steamPressureAutoMan        : BOOL;  // EN: Steam pressure mode (0=Manual, 1=Auto) / PT: Modo de pressão do vapor (0=Manual, 1=Automático)
    steamPressureAutoSetpoint   : REAL;  // EN: Auto mode setpoint [bar] / PT: Setpoint em modo automático [bar]
    steamPressureManualSetpoint : REAL;  // EN: Manual mode setpoint [bar] / PT: Setpoint em modo manual [bar]
    steamPressureFeedback       : REAL;  // EN: Steam pressure feedback [bar] / PT: Retorno de pressão do vapor [bar]
    steamPressureKp             : REAL := 1.0;  // EN: PID proportional gain / PT: Ganho proporcional do PID
    steamPressureTn             : REAL := 8.0;  // EN: PID integral time [s] / PT: Tempo integral do PID [s]
    steamPressureTv             : REAL := 0.0;  // EN: PID derivative time [s] / PT: Tempo derivativo do PID [s]

	steamPressureLimLow             : REAL := 0.0;  // EN: PID proportional gain / PT: Ganho proporcional do PID
    steamPressureLimHigh             : REAL := 3.0;  // EN: PID integral time [s] / PT: Tempo integral do PID [s]

	
	
	upperMasterDiameter	: REAL := 263.878;
	upperSlave1Diameter	: REAL := 1200.980;
	lowerMasterDiameter	: REAL := 263.241;
	lowerSlave1Diameter	: REAL := 263.241;

	
    //==============================================================
    // MACHINE CONFIGURATION STRUCT
    //==============================================================
    machineConfig               : PaperMachine_TypeHmiConfig; // EN: HMI configuration structure / PT: Estrutura de configuração da HMI

END_VAR



VAR_OUTPUT

    //==============================================================
    // STATE & DIAGNOSTICS
    //==============================================================
    deviceState                 : STRING;  // EN: Current readable device state / PT: Estado textual atual do grupo
    groupFault                  : BOOL;    // EN: Group fault active / PT: Falha ativa no grupo
    statusCode                  : INT;     // EN: 0=Idle, 1=Starting, 2=Running, 3=Fault / PT: 0=Parado, 1=Partindo, 2=Rodando, 3=Falha

    //==============================================================
    // DRIVE SPEED REFERENCES (RPM)
    //==============================================================
    upperMasterSpeedSetpointRPM : REAL;
    upperSlaveSpeedSetpointRPM  : REAL;
    lowerMasterSpeedSetpointRPM : REAL;
    lowerSlaveSpeedSetpointRPM  : REAL;


    //==============================================================
    // LINE SPEED & TORQUE REFERENCES
    //==============================================================
    nextGroupSpeedRefMPM        : REAL;  // EN: Suggested next group speed [m/min] / PT: Velocidade sugerida para o próximo grupo [m/min]

    upperSlave1TorqueRefPct     : REAL;
    upperSlave2TorqueRefPct     : REAL;
    lowerSlave1TorqueRefPct     : REAL;
    lowerSlave2TorqueRefPct     : REAL;

    //==============================================================
    // DRIVE ENABLE & RESET COMMANDS
    //==============================================================
    upperMasterEnable           : BOOL;
    upperSlave1Enable           : BOOL;
    upperMasterReset            : BOOL;
    upperSlave1Reset            : BOOL;

    lowerMasterEnable           : BOOL;
    lowerSlave1Enable           : BOOL;
    lowerMasterReset            : BOOL;
    lowerSlave1Reset            : BOOL;

    //==============================================================
    // FABRIC / WIRE STRETCHERS
    //==============================================================
    upperDryingSectionFabricStretch   : BOOL;
    upperDryingSectionFabricUnstretch : BOOL;
    lowerDryingSectionFabricStretch   : BOOL;
    lowerDryingSectionFabricUnstretch : BOOL;

    //==============================================================
    // PICK-UP ROLL POSITIONER OUTPUTS
    //==============================================================
    pickUpRollPosRunFwd          : BOOL;
    pickUpRollPosRunRev          : BOOL;

    //==============================================================
    // SCRAPER OSCILLATORS OUTPUTS
    //==============================================================
    babyDryerScraperOscRun       : BOOL;
    upperGroupScraperOscRun      : BOOL;
    lowerGroupScraperOscRun      : BOOL;

    //==============================================================
    // STEAM PRESSURE PID OUTPUT
    //==============================================================
	steamPressure : REAL; //Steam pressure display
    steamPressureControllerOutput : REAL;

    //==============================================================
    //FEEDBACKS (MPM / RPM / TOQUE)
    //==============================================================
    upperMasterSpeedMPM          : REAL;
    upperSlave1SpeedMPM          : REAL;
    lowerMasterSpeedMPM          : REAL;
    lowerSlave1SpeedMPM          : REAL;

    upperMasterSpeedRPM          : REAL;
    upperSlave1SpeedRPM          : REAL;
    lowerMasterSpeedRPM          : REAL;
    lowerSlave1SpeedRPM          : REAL;
	
    upperMasterTorque          	: REAL;
    upperSlave1Torque          	: REAL;
    lowerMasterTorque          	: REAL;
    lowerSlave1Torque          	: REAL;

    //==============================================================
    // HMI ALARMS STRUCT
    //==============================================================
    hmiAlarms                    : PaperMachine_TypeHmiAlarms;


END_VAR



VAR
    //==============================================================
    // INTERNAL FUNCTION BLOCK INSTANCES
    //==============================================================
    instFB_GroupDriveControl_V1       : FB_GroupDriveControl_V1;
    instFB_GroupSpeedControl_V1       : FB_GroupSpeedControl_V1;
    instFB_GroupDisplayFilters_V1     : FB_GroupDisplayFilters_V1;
    instFB_GroupTorqueTrimControl_V1  : FB_GroupTorqueTrimControl_V1;
    instCTRL_PID_TemperatureController: CTRL_PID;

	instFB_DryingSectionPressureControl : FB_DryingSectionPressureControl;
	
	
	

	instPT1_SteamPressureFiltered: FT_PT1;
	instFB_GroupTorqueTrimControl_V2: FB_GroupTorqueTrimControl_V2;
	upperAndLowerSpeedTrim: REAL;
	instTONGroupFaultDelay: TON;
	
    instTON_OverrunAll : TON;
    overrunAny         : BOOL;
END_VAR



VAR PERSISTENT
    //==============================================================
    // TUNING PARAMETERS (PERSISTENT)
    //==============================================================
    instTUNE2_GroupSpeedDiference     : TUNE2; // EN: Manual tuning helper for group speed difference / PT: Auxiliar de ajuste manual da diferença de velocidade do grupo
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[// ─────────────────────────────────────────────────────────────────────────────
// MAIN CALL SEQUENCE
// ─────────────────────────────────────────────────────────────────────────────

_GroupControl();          // 1) State machine: edges, enables, stop modes

_alarmsDisplay();

_auxiliaryControls();

_SteamPressureControl();

_SteamControl();]]></ST>
    </Implementation>
    <Method Name="_alarmsDisplay" Id="{9b77234c-3f28-48b3-bf16-0e7ee3b7ff20}">
      <Declaration><![CDATA[METHOD _alarmsDisplay
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//==============================================================
// FABRIC OVERRUN — single TON debounce for all sensors
//==============================================================
// Any overrun sensor active (OR of all)?
overrunAny :=
    upperDryingSectionFabricOverrunOperatorSideSensor OR
    upperDryingSectionFabricOverrunDriveSideSensor    OR
    lowerDryingSectionFabricOverrunOperatorSideSensor OR
    lowerDryingSectionFabricOverrunDriveSideSensor;

// Run the single debounce timer
instTON_OverrunAll(IN := overrunAny, PT := T#5S);


//==============================================================
// ALARMS BY GROUP — set on condition; no resets here
//==============================================================
CASE groupNumber OF

    //==============================================================
    // DRYING SECTION GROUP 1 (GR1)
    //==============================================================
    1:
        //----------------------------
        // DRIVES — UPPER (GR1)
        //----------------------------
        IF NOT upperMasterReady THEN
            hmiAlarms.dryingSectionGroup1UpperMasterFaultAlarm := TRUE;
        END_IF;
        IF NOT upperSlave1Ready THEN
            hmiAlarms.dryingSectionGroup1UpperSlave1FaultAlarm := TRUE;
        END_IF;

        //----------------------------
        // COOLING MOTORS — UPPER (GR1)
        //----------------------------
        IF upperMasterCoolingMotorFault THEN
            hmiAlarms.dryingSectionGroup1UpperMasterCoolingFaultAlarm := TRUE;
        END_IF;
        IF upperSlave1CoolingMotorFault THEN
            hmiAlarms.dryingSectionGroup1UpperSlave1CoolingFaultAlarm := TRUE;
        END_IF;

        //----------------------------
        // DRIVES — LOWER (GR1)
        //----------------------------
        IF NOT lowerMasterReady THEN
            hmiAlarms.dryingSectionGroup1LowerMasterFaultAlarm := TRUE;
        END_IF;
        IF NOT lowerSlave1Ready THEN
            hmiAlarms.dryingSectionGroup1LowerSlave1FaultAlarm := TRUE;
        END_IF;


        //----------------------------
        // COOLING MOTORS — LOWER (GR1)
        //----------------------------
        IF lowerMasterCoolingMotorFault THEN
            hmiAlarms.dryingSectionGroup1LowerMasterCoolingFaultAlarm := TRUE;
        END_IF;
        IF lowerSlave1CoolingMotorFault THEN
            hmiAlarms.dryingSectionGroup1LowerSlave1CoolingFaultAlarm := TRUE;
        END_IF;

        //----------------------------
        // FABRIC OVERRUN SENSORS (GR1) — gated by TON
        //----------------------------
        IF upperDryingSectionFabricOverrunOperatorSideSensor AND instTON_OverrunAll.Q THEN
            hmiAlarms.upperDryingSectionGroup1FabricOverrunOperatorSideAlarm := TRUE;
        END_IF;
        IF upperDryingSectionFabricOverrunDriveSideSensor AND instTON_OverrunAll.Q THEN
            hmiAlarms.upperDryingSectionGroup1FabricOverrunDriveSideAlarm := TRUE;
        END_IF;
        IF lowerDryingSectionFabricOverrunOperatorSideSensor AND instTON_OverrunAll.Q THEN
            hmiAlarms.lowerDryingSectionGroup1FabricOverrunOperatorSideAlarm := TRUE;
        END_IF;
        IF lowerDryingSectionFabricOverrunDriveSideSensor AND instTON_OverrunAll.Q THEN
            hmiAlarms.lowerDryingSectionGroup1FabricOverrunDriveSideAlarm := TRUE;
        END_IF;

        //----------------------------
        // FABRIC STRETCHER MOTOR FAULTS (GR1)
        //----------------------------
        IF upperDryingSectionFabricStretcherMotorFault THEN
            hmiAlarms.upperDryingSectionGroup1FabricStretcherMotorFaultAlarm := TRUE;
        END_IF;
        IF lowerDryingSectionFabricStretcherMotorFault THEN
            hmiAlarms.lowerDryingSectionGroup1FabricStretcherMotorFaultAlarm := TRUE;
        END_IF;

        //----------------------------
        // PICK-UP ROLL POSITIONER (GR1)
        //----------------------------
        IF pickUpRollPosFault THEN
            hmiAlarms.dryingSectionGroup1PickUpRollPosFaultAlarm := TRUE;
        END_IF;

        //----------------------------
        // SCRAPER OSCILLATORS (GR1)
        //----------------------------
        IF babyDryerScraperOscFault THEN
            hmiAlarms.dryingSectionGroup1BabyDryerScraperOscFaultAlarm := TRUE;
        END_IF;
        IF upperGroupScraperOscFault THEN
            hmiAlarms.dryingSectionGroup1UpperScraperOscFaultAlarm := TRUE;
        END_IF;
        IF lowerGroupScraperOscFault THEN
            hmiAlarms.dryingSectionGroup1LowerScraperOscFaultAlarm := TRUE;
        END_IF;


    //==============================================================
    // DRYING SECTION GROUP 2 (GR2)
    //==============================================================
    2:
        //----------------------------
        // DRIVES — UPPER (GR2)
        //----------------------------
        IF NOT upperMasterReady THEN
            hmiAlarms.dryingSectionGroup2UpperMasterFaultAlarm := TRUE;
        END_IF;
        IF NOT upperSlave1Ready THEN
            hmiAlarms.dryingSectionGroup2UpperSlave1FaultAlarm := TRUE;
        END_IF;

        //----------------------------
        // COOLING MOTORS — UPPER (GR2)
        //----------------------------
        IF upperMasterCoolingMotorFault THEN
            hmiAlarms.dryingSectionGroup2UpperMasterCoolingFaultAlarm := TRUE;
        END_IF;
        IF upperSlave1CoolingMotorFault THEN
            hmiAlarms.dryingSectionGroup2UpperSlave1CoolingFaultAlarm := TRUE;
        END_IF;

        //----------------------------
        // DRIVES — LOWER (GR2)
        //----------------------------
        IF NOT lowerMasterReady THEN
            hmiAlarms.dryingSectionGroup2LowerMasterFaultAlarm := TRUE;
        END_IF;
        IF NOT lowerSlave1Ready THEN
            hmiAlarms.dryingSectionGroup2LowerSlave1FaultAlarm := TRUE;
        END_IF;

        //----------------------------
        // COOLING MOTORS — LOWER (GR2)
        //----------------------------
        IF lowerMasterCoolingMotorFault THEN
            hmiAlarms.dryingSectionGroup2LowerMasterCoolingFaultAlarm := TRUE;
        END_IF;
        IF lowerSlave1CoolingMotorFault THEN
            hmiAlarms.dryingSectionGroup2LowerSlave1CoolingFaultAlarm := TRUE;
        END_IF;

        //----------------------------
        // FABRIC OVERRUN SENSORS (GR2) — gated by TON
        //----------------------------
        IF upperDryingSectionFabricOverrunOperatorSideSensor AND instTON_OverrunAll.Q THEN
            hmiAlarms.upperDryingSectionGroup2FabricOverrunOperatorSideAlarm := TRUE;
        END_IF;
        IF upperDryingSectionFabricOverrunDriveSideSensor AND instTON_OverrunAll.Q THEN
            hmiAlarms.upperDryingSectionGroup2FabricOverrunDriveSideAlarm := TRUE;
        END_IF;
        IF lowerDryingSectionFabricOverrunOperatorSideSensor AND instTON_OverrunAll.Q THEN
            hmiAlarms.lowerDryingSectionGroup2FabricOverrunOperatorSideAlarm := TRUE;
        END_IF;
        IF lowerDryingSectionFabricOverrunDriveSideSensor AND instTON_OverrunAll.Q THEN
            hmiAlarms.lowerDryingSectionGroup2FabricOverrunDriveSideAlarm := TRUE;
        END_IF;

        //----------------------------
        // FABRIC STRETCHER MOTOR FAULTS (GR2)
        //----------------------------
        IF upperDryingSectionFabricStretcherMotorFault THEN
            hmiAlarms.upperDryingSectionGroup2FabricStretcherMotorFaultAlarm := TRUE;
        END_IF;
        IF lowerDryingSectionFabricStretcherMotorFault THEN
            hmiAlarms.lowerDryingSectionGroup2FabricStretcherMotorFaultAlarm := TRUE;
        END_IF;


    //==============================================================
    // DRYING SECTION GROUP 3 (GR3)
    //==============================================================
    3:
        //----------------------------
        // DRIVES — UPPER (GR3)
        //----------------------------
        IF NOT upperMasterReady THEN
            hmiAlarms.dryingSectionGroup3UpperMasterFaultAlarm := TRUE;
        END_IF;
        IF NOT upperSlave1Ready THEN
            hmiAlarms.dryingSectionGroup3UpperSlave1FaultAlarm := TRUE;
        END_IF;

        //----------------------------
        // COOLING MOTORS — UPPER (GR3)
        //----------------------------
        IF upperMasterCoolingMotorFault THEN
            hmiAlarms.dryingSectionGroup3UpperMasterCoolingFaultAlarm := TRUE;
        END_IF;
        IF upperSlave1CoolingMotorFault THEN
            hmiAlarms.dryingSectionGroup3UpperSlave1CoolingFaultAlarm := TRUE;
        END_IF;

        //----------------------------
        // DRIVES — LOWER (GR3)
        //----------------------------
        IF NOT lowerMasterReady THEN
            hmiAlarms.dryingSectionGroup3LowerMasterFaultAlarm := TRUE;
        END_IF;
        IF NOT lowerSlave1Ready THEN
            hmiAlarms.dryingSectionGroup3LowerSlave1FaultAlarm := TRUE;
        END_IF;


        //----------------------------
        // COOLING MOTORS — LOWER (GR3)
        //----------------------------
        IF lowerMasterCoolingMotorFault THEN
            hmiAlarms.dryingSectionGroup3LowerMasterCoolingFaultAlarm := TRUE;
        END_IF;
        IF lowerSlave1CoolingMotorFault THEN
            hmiAlarms.dryingSectionGroup3LowerSlave1CoolingFaultAlarm := TRUE;
        END_IF;

        //----------------------------
        // FABRIC OVERRUN SENSORS (GR3) — gated by TON
        //----------------------------
        IF upperDryingSectionFabricOverrunOperatorSideSensor AND instTON_OverrunAll.Q THEN
            hmiAlarms.upperDryingSectionGroup3FabricOverrunOperatorSideAlarm := TRUE;
        END_IF;
        IF upperDryingSectionFabricOverrunDriveSideSensor AND instTON_OverrunAll.Q THEN
            hmiAlarms.upperDryingSectionGroup3FabricOverrunDriveSideAlarm := TRUE;
        END_IF;
        IF lowerDryingSectionFabricOverrunOperatorSideSensor AND instTON_OverrunAll.Q THEN
            hmiAlarms.lowerDryingSectionGroup3FabricOverrunOperatorSideAlarm := TRUE;
        END_IF;
        IF lowerDryingSectionFabricOverrunDriveSideSensor AND instTON_OverrunAll.Q THEN
            hmiAlarms.lowerDryingSectionGroup3FabricOverrunDriveSideAlarm := TRUE;
        END_IF;

        //----------------------------
        // FABRIC STRETCHER MOTOR FAULTS (GR3)
        //----------------------------
        IF upperDryingSectionFabricStretcherMotorFault THEN
            hmiAlarms.upperDryingSectionGroup3FabricStretcherMotorFaultAlarm := TRUE;
        END_IF;
        IF lowerDryingSectionFabricStretcherMotorFault THEN
            hmiAlarms.lowerDryingSectionGroup3FabricStretcherMotorFaultAlarm := TRUE;
        END_IF;

ELSE
    // invalid group → do nothing (fail-safe handled below)
END_CASE;


//==============================================================
// GROUP FAULT — CURRENT GROUP (uses the HMI alarm bits)
//==============================================================
CASE groupNumber OF
    1:
        groupFault :=
            hmiAlarms.dryingSectionGroup1UpperMasterFaultAlarm OR
            hmiAlarms.dryingSectionGroup1UpperSlave1FaultAlarm OR
            hmiAlarms.dryingSectionGroup1UpperSlave2FaultAlarm OR
            hmiAlarms.dryingSectionGroup1LowerMasterFaultAlarm OR
            hmiAlarms.dryingSectionGroup1LowerSlave1FaultAlarm OR
            hmiAlarms.dryingSectionGroup1LowerSlave2FaultAlarm OR
            hmiAlarms.upperDryingSectionGroup1FabricOverrunOperatorSideAlarm OR
            hmiAlarms.upperDryingSectionGroup1FabricOverrunDriveSideAlarm OR
            hmiAlarms.lowerDryingSectionGroup1FabricOverrunOperatorSideAlarm OR
            hmiAlarms.lowerDryingSectionGroup1FabricOverrunDriveSideAlarm;

    2:
        groupFault :=
            hmiAlarms.dryingSectionGroup2UpperMasterFaultAlarm OR
            hmiAlarms.dryingSectionGroup2UpperSlave1FaultAlarm OR
            hmiAlarms.dryingSectionGroup2UpperSlave2FaultAlarm OR
            hmiAlarms.dryingSectionGroup2LowerMasterFaultAlarm OR
            hmiAlarms.dryingSectionGroup2LowerSlave1FaultAlarm OR
            hmiAlarms.dryingSectionGroup2LowerSlave2FaultAlarm OR
            hmiAlarms.upperDryingSectionGroup2FabricOverrunOperatorSideAlarm OR
            hmiAlarms.upperDryingSectionGroup2FabricOverrunDriveSideAlarm OR
            hmiAlarms.lowerDryingSectionGroup2FabricOverrunOperatorSideAlarm OR
            hmiAlarms.lowerDryingSectionGroup2FabricOverrunDriveSideAlarm;

    3:
        groupFault :=
            hmiAlarms.dryingSectionGroup3UpperMasterFaultAlarm OR
            hmiAlarms.dryingSectionGroup3UpperSlave1FaultAlarm OR
            hmiAlarms.dryingSectionGroup3UpperSlave2FaultAlarm OR
            hmiAlarms.dryingSectionGroup3LowerMasterFaultAlarm OR
            hmiAlarms.dryingSectionGroup3LowerSlave1FaultAlarm OR
            hmiAlarms.dryingSectionGroup3LowerSlave2FaultAlarm OR
            hmiAlarms.upperDryingSectionGroup3FabricOverrunOperatorSideAlarm OR
            hmiAlarms.upperDryingSectionGroup3FabricOverrunDriveSideAlarm OR
            hmiAlarms.lowerDryingSectionGroup3FabricOverrunOperatorSideAlarm OR
            hmiAlarms.lowerDryingSectionGroup3FabricOverrunDriveSideAlarm;
ELSE
    groupFault := TRUE; // fail-safe
END_CASE;

//==============================================================
// NOTE: No reset logic here. HMI reset can be added later.
//==============================================================
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_auxiliaryControls" Id="{412aa673-a79e-4a17-8180-cd1d1d9ab7b6}">
      <Declaration><![CDATA[METHOD _auxiliaryControls
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
//-----------------------------
// UPPER FABRIC STRETCHER
//-----------------------------
// EN: Block if motor fault or limit reached
//* PT: Bloqueia se falha de motor ou fim de curso atingido */
IF NOT upperDryingSectionFabricStretcherMotorFault THEN

    // Stretch (only if not at MAX limit)
    IF upperDryingSectionFabricStretchCmd
       AND NOT upperDryingSectionFabricUnstretchCmd
       AND NOT upperDryingSectionFabricStretchLimMax THEN
        upperDryingSectionFabricStretch := TRUE;
    ELSE
        upperDryingSectionFabricStretch := FALSE;
    END_IF;

    // Unstretch (only if not at MIN limit)
    IF upperDryingSectionFabricUnstretchCmd
       AND NOT upperDryingSectionFabricStretchCmd
       AND NOT upperDryingSectionFabricStretchLimMin THEN
        upperDryingSectionFabricUnstretch := TRUE;
    ELSE
        upperDryingSectionFabricUnstretch := FALSE;
    END_IF;

ELSE
    // Fault detected → both off
    upperDryingSectionFabricStretch   := FALSE;
    upperDryingSectionFabricUnstretch := FALSE;
END_IF;


//-----------------------------
// LOWER FABRIC STRETCHER
//-----------------------------
// EN: Block if motor fault or limit reached
//* PT: Bloqueia se falha de motor ou fim de curso atingido */
IF NOT lowerDryingSectionFabricStretcherMotorFault THEN

    // Stretch (only if not at MAX limit)
    IF lowerDryingSectionFabricStretchCmd
       AND NOT lowerDryingSectionFabricUnstretchCmd
       AND NOT lowerDryingSectionFabricStretchLimMax THEN
        lowerDryingSectionFabricStretch := TRUE;
    ELSE
        lowerDryingSectionFabricStretch := FALSE;
    END_IF;

    // Unstretch (only if not at MIN limit)
    IF lowerDryingSectionFabricUnstretchCmd
       AND NOT lowerDryingSectionFabricStretchCmd
       AND NOT lowerDryingSectionFabricStretchLimMin THEN
        lowerDryingSectionFabricUnstretch := TRUE;
    ELSE
        lowerDryingSectionFabricUnstretch := FALSE;
    END_IF;

ELSE
    // Fault detected → both off
    lowerDryingSectionFabricStretch   := FALSE;
    lowerDryingSectionFabricUnstretch := FALSE;
END_IF;


//==============================================
// PICK-UP ROLL POSITIONER
//  - Uses: pickUpRollPosCmdFwd / pickUpRollPosCmdRev
//  - Safety: fault or limit reached → stop
//  - Safety (optional): if both cmds = TRUE, stop
//==============================================
IF NOT pickUpRollPosFault THEN
    // Forward
    IF pickUpRollPosCmdFwd
       AND NOT pickUpRollPosCmdRev
       AND NOT pickUpRollPosLimitFwd THEN
        // EN: run forward / PT: avança
        pickUpRollPosRunFwd := TRUE;
    ELSE
        pickUpRollPosRunFwd := FALSE;
    END_IF;

    // Reverse
    IF pickUpRollPosCmdRev
       AND NOT pickUpRollPosCmdFwd
       AND NOT pickUpRollPosLimitRev THEN
        // EN: run reverse / PT: recua
        pickUpRollPosRunRev := TRUE;
    ELSE
        pickUpRollPosRunRev := FALSE;
    END_IF;
ELSE
    // EN: Fault → stop / PT: Falha → para
    pickUpRollPosRunFwd := FALSE;
    pickUpRollPosRunRev := FALSE;
END_IF;



//==============================================
// SCRAPER OSCILLATORS
//  - Babydryer
//  - Upper group
//  - Lower group
//  - Safety: fault → stop output
//==============================================

//-----------------------------
// BABYDRYER SCRAPER OSCILLATOR
//-----------------------------
IF NOT babyDryerScraperOscFault THEN
    // EN: run only if command is active / PT: aciona somente se houver comando
    IF babyDryerScraperOscCmd AND upperMasterSpeedMPM > 10 THEN
        babyDryerScraperOscRun := TRUE;
    ELSE
        babyDryerScraperOscRun := FALSE;
    END_IF;
ELSE
    // EN: fault → force off / PT: falha → força desligado
    babyDryerScraperOscRun := FALSE;
END_IF;


//-----------------------------
// UPPER GROUP SCRAPER OSCILLATOR
//-----------------------------
IF NOT upperGroupScraperOscFault THEN
    IF upperGroupScraperOscCmd AND upperMasterSpeedMPM > 10 THEN
        upperGroupScraperOscRun := TRUE;
    ELSE
        upperGroupScraperOscRun := FALSE;
    END_IF;
ELSE
    upperGroupScraperOscRun := FALSE;
END_IF;


//-----------------------------
// LOWER GROUP SCRAPER OSCILLATOR
//-----------------------------
IF NOT lowerGroupScraperOscFault AND lowerMasterSpeedMPM > 10 THEN
    IF lowerGroupScraperOscCmd THEN
        lowerGroupScraperOscRun := TRUE;
    ELSE
        lowerGroupScraperOscRun := FALSE;
    END_IF;
ELSE
    lowerGroupScraperOscRun := FALSE;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_GroupControl" Id="{491a6b88-5cf9-4468-8afd-a749a31a70c7}">
      <Declaration><![CDATA[METHOD _GroupControl
VAR_INPUT
END_VAR
(*
FUNCTION_BLOCK FB_DryingSectionDriveControl_V3
VAR_INPUT

    //==============================================================
    // GROUP INTERLOCKS & COMMANDS
    //==============================================================
    startGroup              : BOOL;  // EN: Start command (pulse) / PT: Comando de partida (pulso)
    stopGroup               : BOOL;  // EN: Stop command (level) / PT: Comando de parada (nível)
    groupReset              : BOOL;  // EN: Reset group faults / PT: Reset de falhas do grupo

    //==============================================================
    // SPEED OFFSET / MANUAL ADJUSTMENTS
    //==============================================================
    grouSpeedDifIncCmd      : BOOL;  // EN: Lamp or indication – speed offset increasing / PT: Lâmpada ou indicação – offset de velocidade aumentando
    grouSpeedDifDecCmd      : BOOL;  // EN: Lamp or indication – speed offset decreasing / PT: Lâmpada ou indicação – offset de velocidade reduzindo
    groupRecoverSpeedCmd    : BOOL;  // EN: Recover nominal speed while TRUE / PT: Recuperar velocidade nominal enquanto TRUE

    //==============================================================
    // DRIVE STATUS INPUTS — UPPER GROUP
    //==============================================================
    upperMasterReady        : BOOL;  // EN: Upper master ready (no trip) / PT: Mestre superior pronto (sem falha)
    upperSlave1Ready        : BOOL;  // EN: Upper slave 1 ready / PT: Escravo 1 superior pronto

    //==============================================================
    // DRIVE STATUS INPUTS — LOWER GROUP
    //==============================================================
    lowerMasterReady        : BOOL;  // EN: Lower master ready (no trip) / PT: Mestre inferior pronto (sem falha)
    lowerSlave1Ready        : BOOL;  // EN: Lower slave 1 ready / PT: Escravo 1 inferior pronto

    //==============================================================
    // SPEED SETPOINTS & MODE SELECTION
    //==============================================================
    groupAutoSpeedMPM       : REAL;        // EN: Automatic mode speed [m/min] / PT: Velocidade em modo automático [m/min]
    groupManualSpeedMPM     : REAL := 50.0;// EN: Manual mode speed [m/min] / PT: Velocidade em modo manual [m/min]
    groupSpeedAutoMan       : BOOL;        // EN: Speed mode (0=Manual, 1=Auto) / PT: Modo de velocidade (0=Manual, 1=Automático)

    //==============================================================
    // SPEED & TORQUE FEEDBACKS — UPPER GROUP
    //==============================================================
    upperMasterSpeedFeedback    : REAL;  // [m/min or %]
    upperMasterTorqueFeedback   : REAL;  // [% or Nm]
    upperSlave1SpeedFeedback    : REAL;
    upperSlave1TorqueFeedback   : REAL;

    //==============================================================
    // SPEED & TORQUE FEEDBACKS — LOWER GROUP
    //==============================================================
    lowerMasterSpeedFeedback    : REAL;
    lowerMasterTorqueFeedback   : REAL;
    lowerSlave1SpeedFeedback    : REAL;
    lowerSlave1TorqueFeedback   : REAL;

    //==============================================================
    // COOLING MOTOR FAULT INPUTS
    //==============================================================
    upperMasterCoolingMotorFault : BOOL;  // EN: Upper master cooling motor fault / PT: Falha no motor de ventilação do mestre superior
    upperSlave1CoolingMotorFault : BOOL;  // EN: Upper slave 1 cooling motor fault / PT: Falha no motor de ventilação do escravo 1 superior
    lowerMasterCoolingMotorFault : BOOL;  // EN: Lower master cooling motor fault / PT: Falha no motor de ventilação do mestre inferior
    lowerSlave1CoolingMotorFault : BOOL;  // EN: Lower slave 1 cooling motor fault / PT: Falha no motor de ventilação do escravo 1 inferior

    //==============================================================
    // FABRIC / WIRE STRETCHER ACTUATORS
    //==============================================================
    upperDryingSectionFabricStretchCmd     : BOOL;  // EN: Command to stretch upper fabric / PT: Comando para esticar a tela superior
    upperDryingSectionFabricUnstretchCmd   : BOOL;  // EN: Command to loosen upper fabric / PT: Comando para afrouxar a tela superior
    lowerDryingSectionFabricStretchCmd     : BOOL;  // EN: Command to stretch lower fabric / PT: Comando para esticar a tela inferior
    lowerDryingSectionFabricUnstretchCmd   : BOOL;  // EN: Command to loosen lower fabric / PT: Comando para afrouxar a tela inferior
    upperDryingSectionFabricStretcherMotorFault : BOOL;  // EN: Upper stretcher motor fault / PT: Falha no motor de estiramento superior
    lowerDryingSectionFabricStretcherMotorFault : BOOL;  // EN: Lower stretcher motor fault / PT: Falha no motor de estiramento inferior

    //==============================================================
    // FABRIC / WIRE OVERRUN SENSORS
    //==============================================================
    upperDryingSectionFabricOverrunOperatorSideSensor : BOOL; // EN: Upper fabric overrun sensor (operator side) / PT: Sensor de sobrecurso da tela superior (lado operador)
    upperDryingSectionFabricOverrunDriveSideSensor    : BOOL; // EN: Upper fabric overrun sensor (drive side) / PT: Sensor de sobrecurso da tela superior (lado acionamento)
    lowerDryingSectionFabricOverrunOperatorSideSensor : BOOL; // EN: Lower fabric overrun sensor (operator side) / PT: Sensor de sobrecurso da tela inferior (lado operador)
    lowerDryingSectionFabricOverrunDriveSideSensor    : BOOL; // EN: Lower fabric overrun sensor (drive side) / PT: Sensor de sobrecurso da tela inferior (lado acionamento)

    //==============================================================
    // PICK-UP ROLL POSITIONER
    //==============================================================
    pickUpRollPosCmdFwd       : BOOL;  // EN: Command forward / PT: Avanço do rolo pick-up
    pickUpRollPosCmdRev       : BOOL;  // EN: Command reverse / PT: Recuo do rolo pick-up
    pickUpRollPosLimitFwd     : BOOL;  // EN: Forward limit switch / PT: Fim de curso frontal
    pickUpRollPosLimitRev     : BOOL;  // EN: Reverse limit switch / PT: Fim de curso traseiro
    pickUpRollPosFault        : BOOL;  // EN: Positioner fault / PT: Falha no posicionador

    //==============================================================
    // SCRAPER OSCILLATORS
    //==============================================================
    babyDryerScraperOscCmd     : BOOL;  // EN: Command to start Baby Dryer scraper oscillator / PT: Comando para iniciar oscilador do Baby Dryer
    babyDryerScraperOscFault   : BOOL;  // EN: Baby Dryer oscillator fault / PT: Falha no oscilador do Baby Dryer
    babyDryerScraperOscRunning : BOOL;  // EN: Baby Dryer oscillator running / PT: Oscilador do Baby Dryer em operação

    upperGroupScraperOscCmd     : BOOL;  // EN: Upper group scraper oscillator command / PT: Comando de oscilação da raspa do grupo superior
    upperGroupScraperOscFault   : BOOL;  // EN: Upper group oscillator fault / PT: Falha no oscilador do grupo superior
    upperGroupScraperOscRunning : BOOL;  // EN: Upper group oscillator running / PT: Oscilador do grupo superior em operação

    lowerGroupScraperOscCmd     : BOOL;  // EN: Lower group scraper oscillator command / PT: Comando de oscilação da raspa do grupo inferior
    lowerGroupScraperOscFault   : BOOL;  // EN: Lower group oscillator fault / PT: Falha no oscilador do grupo inferior
    lowerGroupScraperOscRunning : BOOL;  // EN: Lower group oscillator running / PT: Oscilador do grupo inferior em operação

    //==============================================================
    // STEAM PRESSURE CONTROL (PID)
    //==============================================================
    steamPressureAutoMan        : BOOL;  // EN: Steam pressure mode (0=Manual, 1=Auto) / PT: Modo de pressão do vapor (0=Manual, 1=Automático)
    steamPressureAutoSetpoint   : REAL;  // EN: Auto mode setpoint [bar] / PT: Setpoint em modo automático [bar]
    steamPressureManualSetpoint : REAL;  // EN: Manual mode setpoint [bar] / PT: Setpoint em modo manual [bar]
    steamPressureFeedback       : REAL;  // EN: Steam pressure feedback [bar] / PT: Retorno de pressão do vapor [bar]
    steamPressureKp             : REAL := 1.0;  // EN: PID proportional gain / PT: Ganho proporcional do PID
    steamPressureTn             : REAL := 8.0;  // EN: PID integral time [s] / PT: Tempo integral do PID [s]
    steamPressureTv             : REAL := 0.0;  // EN: PID derivative time [s] / PT: Tempo derivativo do PID [s]

    //==============================================================
    // MACHINE CONFIGURATION STRUCT
    //==============================================================
    machineConfig               : PaperMachine_TypeHmiConfig; // EN: HMI configuration structure / PT: Estrutura de configuração da HMI

END_VAR



VAR_OUTPUT

    //==============================================================
    // STATE & DIAGNOSTICS
    //==============================================================
    deviceState                 : STRING;  // EN: Current readable device state / PT: Estado textual atual do grupo
    groupFault                  : BOOL;    // EN: Group fault active / PT: Falha ativa no grupo
    statusCode                  : INT;     // EN: 0=Idle, 1=Starting, 2=Running, 3=Fault / PT: 0=Parado, 1=Partindo, 2=Rodando, 3=Falha

    //==============================================================
    // DRIVE SPEED REFERENCES (RPM)
    //==============================================================
    upperMasterSpeedSetpointRPM : REAL;
    upperSlaveSpeedSetpointRPM  : REAL;
    lowerMasterSpeedSetpointRPM : REAL;
    lowerSlaveSpeedSetpointRPM  : REAL;


    //==============================================================
    // LINE SPEED & TORQUE REFERENCES
    //==============================================================
    nextGroupSpeedRefMPM        : REAL;  // EN: Suggested next group speed [m/min] / PT: Velocidade sugerida para o próximo grupo [m/min]

    upperSlave1TorqueRefPct     : REAL;
    upperSlave2TorqueRefPct     : REAL;
    lowerSlave1TorqueRefPct     : REAL;
    lowerSlave2TorqueRefPct     : REAL;

    //==============================================================
    // DRIVE ENABLE & RESET COMMANDS
    //==============================================================
    upperMasterEnable           : BOOL;
    upperSlave1Enable           : BOOL;
    upperMasterReset            : BOOL;
    upperSlave1Reset            : BOOL;

    lowerMasterEnable           : BOOL;
    lowerSlave1Enable           : BOOL;
    lowerMasterReset            : BOOL;
    lowerSlave1Reset            : BOOL;

    //==============================================================
    // FABRIC / WIRE STRETCHERS
    //==============================================================
    upperDryingSectionFabricStretch   : BOOL;
    upperDryingSectionFabricUnstretch : BOOL;
    lowerDryingSectionFabricStretch   : BOOL;
    lowerDryingSectionFabricUnstretch : BOOL;

    //==============================================================
    // PICK-UP ROLL POSITIONER OUTPUTS
    //==============================================================
    pickUpRollPosRunFwd          : BOOL;
    pickUpRollPosRunRev          : BOOL;

    //==============================================================
    // SCRAPER OSCILLATORS OUTPUTS
    //==============================================================
    babyDryerScraperOscRun       : BOOL;
    upperGroupScraperOscRun      : BOOL;
    lowerGroupScraperOscRun      : BOOL;

    //==============================================================
    // STEAM PRESSURE PID OUTPUT
    //==============================================================
    steamPressureControllerOutput : REAL;

    //==============================================================
    //FEEDBACKS (MPM / RPM / TOQUE)
    //==============================================================
    upperMasterSpeedMPM          : REAL;
    upperSlave1SpeedMPM          : REAL;
    lowerMasterSpeedMPM          : REAL;
    lowerSlave1SpeedMPM          : REAL;

    upperMasterSpeedRPM          : REAL;
    upperSlave1SpeedRPM          : REAL;
    lowerMasterSpeedRPM          : REAL;
    lowerSlave1SpeedRPM          : REAL;
	
    upperMasterTorque          	: REAL;
    upperSlave1Torqu          	: REAL;
    lowerMasterTorque          	: REAL;
    lowerSlave1Torque          	: REAL;

    //==============================================================
    // HMI ALARMS STRUCT
    //==============================================================
    hmiAlarms                    : PaperMachine_TypeHmiAlarms;

END_VAR



VAR
    //==============================================================
    // INTERNAL FUNCTION BLOCK INSTANCES
    //==============================================================
    instFB_GroupDriveControl_V1       : FB_GroupDriveControl_V1;
    instFB_GroupSpeedControl_V1       : FB_GroupSpeedControl_V1;
    instFB_GroupDisplayFilters_V1     : FB_GroupDisplayFilters_V1;
    instFB_GroupTorqueTrimControl_V1  : FB_GroupTorqueTrimControl_V1;
    instCTRL_PID_TemperatureController: CTRL_PID;

END_VAR



VAR PERSISTENT
    //==============================================================
    // TUNING PARAMETERS (PERSISTENT)
    //==============================================================
    instTUNE2_GroupSpeedDiference     : TUNE2; // EN: Manual tuning helper for group speed difference / PT: Auxiliar de ajuste manual da diferença de velocidade do grupo
END_VAR

	
*)]]></Declaration>
