    <Method Name="_SteamPressureControl" Id="{9632afd7-a4c4-452c-8750-8e09d30f5b56}">
      <Declaration><![CDATA[METHOD _SteamPressureControl
VAR_INPUT

END_VAR

(*
	steamPressureLimLow             : REAL := 0.0;  // EN: PID proportional gain / PT: Ganho proporcional do PID
    steamPressureLimHigh             : REAL := 3.0;  // EN: PID integral time [s] / PT: Tempo integral do PID [s]

	

*)]]></Declaration>
      <Implementation>
        <ST><![CDATA[//────────────────────────────────────
// PT1 FILTER — Smooth feedback input
//────────────────────────────────────
instPT1_SteamPressureFiltered(
    in  := steamPressureFeedback,
    T   := T#1S,
    K   := 1.0,
    out => steamPressure
);

//────────────────────────────────────────────────────────────
// PID — Steam Pressure Control
//────────────────────────────────────────────────────────────
instCTRL_PID_TemperatureController(
    ACT := steamPressureFeedback,                          // Real-time feedback (PV)
    SET := SEL(steamPressureAutoMan,                       // Setpoint selection
               steamPressureManualSetpoint,                // Manual setpoint
               steamPressureAutoSetpoint),                 // Auto setpoint
    MAN := steamPressureAutoMan = FALSE,                   // Manual mode when AutoMan is FALSE
    M_I := steamPressureManualSetpoint,                    // Tracks manual setpoint
    RST := FALSE,                                          // No reset
    KP  := steamPressureKp,                               
    TN  := steamPressureTn,                               
    TV  := steamPressureTv,                               
    LL  := steamPressureLimLow,                                            // Output lower limit
    LH  := steamPressureLimHigh,                                          // Output upper limit [%]
    Y   => steamPressureControllerOutput                   // PID output
);
]]></ST>
      </Implementation>
    </Method>
