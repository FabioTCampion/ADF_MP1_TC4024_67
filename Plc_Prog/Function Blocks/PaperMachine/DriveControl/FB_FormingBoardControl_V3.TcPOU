    <Method Name="_Scale" Id="{d272cee9-8d42-4951-b59a-a0a5b87266ed}">
      <Declaration><![CDATA[METHOD PRIVATE _Scale : REAL
VAR_INPUT
    X    : REAL;
    I_LO : REAL;
    I_HI : REAL;
    O_LO : REAL;
    O_HI : REAL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF I_LO = I_HI THEN
	_Scale := O_LO;
ELSE
	_Scale := (O_HI - O_LO) / (I_HI - I_LO) * (LIMIT(I_LO, X, I_HI) - I_LO) + O_LO;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_SpeedDifferenceCheck" Id="{517346dd-3710-4c3a-b13d-3a526144ca07}">
      <Declaration><![CDATA[// ============================== Methods ==============================
// Intra-section speed supervision for Press Section (firstPress ↔ secondPress)
METHOD _SpeedDifferenceCheck
(*

    tractionRollSpeedFeedbackMPM : REAL; // MASTER speed feedback [m/min]
    suctionRollSpeedFeedbackMPM  : REAL; // SLAVE speed feedback [m/min]

*)]]></Declaration>
      <Implementation>
        <ST><![CDATA[

speedDif := ABS(tractionRollSpeedFeedbackMPM - suctionRollSpeedFeedbackMPM);


IF speedDif > 50 THEN
	
	speedDifError := TRUE;
	
	ELSE
		
	speedDifError := FALSE;
	
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="_StateDisplay" Id="{c51260d8-b357-494a-859d-3b8c07339490}">
      <Declaration><![CDATA[METHOD _StateDisplay
VAR_INPUT
END_VAR

// ──────────────────────────────────────────────────────────────────────────────
// _StateDisplay — Press Section (firstPress = Master, secondPress = Slave)
// Maps the internal machine "state" to a compact HMI status code and derives
// per-drive motor status codes from VFD signals.
//
// statusCode / firstPressStatusCode / secondPressStatusCode legend:
//   0 = Idle, 1 = Starting, 2 = Running, 3 = Fault
//
// Machine "state" groups:
//   0 = IDLE, 1 = ENABLE, 2 = WAIT_EN, 3 = RAMP_EN, 4 = RUN, 5 = STOPPING, 10 = FAULT
// Priority rule (for motors): Fault > Running > Starting > Idle
// ──────────────────────────────────────────────────────────────────────────────
VAR CONSTANT
    STATUS_IDLE     : INT := 0;
    STATUS_STARTING : INT := 1;
    STATUS_RUNNING  : INT := 2;
    STATUS_FAULT    : INT := 3;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
