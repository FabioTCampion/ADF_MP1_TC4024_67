    <Method Name="_riderRollControl" Id="{708661f7-7f17-4e49-96df-64bb15af1f7c}">
      <Declaration><![CDATA[METHOD _riderRollControl


(*
	operatorSideLastePressure : REAL;
	driveSideLastePressure : REAL;
	
	riderRollWorkPositionCmd	: BOOL;
	riderRollReleasePositionCmd	: BOOL;


*)
]]></Declaration>
      <Implementation>
        <ST><![CDATA[

rRiderRollWorkPositionCmd := riderRollWorkPositionCmd AND NOT riderRollWorkPositionCmdOld;

rRiderRollReleasePositionCmd := riderRollReleasePositionCmd AND NOT riderRollReleasePositionCmdOld;
 

	
IF rRiderRollWorkPositionCmd THEN
	
	riderRollState := 2;
	
END_IF


IF rRiderRollReleasePositionCmd THEN
	
	riderRollState := 1;

END_IF

riderRollWorkPositionCmdOld := riderRollWorkPositionCmd;
riderRollReleasePositionCmdOld := riderRollReleasePositionCmd;

//==============================================================
// State machine (Rider Roll)
//==============================================================
CASE riderRollState OF

//------------------------------------------------------------------
// 0: IDLE
//------------------------------------------------------------------
0:

	instTONAdvanceTime.IN := FALSE;


//------------------------------------------------------------------
// 1: RELEASE POSITION - PRESSURE TO MIN VALUE
//------------------------------------------------------------------
1:

	//Save the last setpoint
	operatorSideLastePressure := instTUNE2_PressureOperatorSide.Y;
	driveSideLastePressure := instTUNE2_PressureDriveSide.Y;

    instTUNE2_PressureOperatorSide.SET_val := 0.0;  // Max pressure
    instTUNE2_PressureOperatorSide.SET := TRUE;
	instTUNE2_PressureOperatorSide();
	
    instTUNE2_PressureDriveSide.SET_val := 0.0;  // Max pressure
    instTUNE2_PressureDriveSide.SET := TRUE;
	instTUNE2_PressureDriveSide();

    // Command solenoid to release position
    riderRollSolenoid1 := TRUE;
    riderRollSolenoid2 := TRUE;
	
	
	//Wait for command
	riderRollState := 0;




//------------------------------------------------------------------
// 2: FAST ADVANCE - PRESSURE TO MAX VALUE
//------------------------------------------------------------------
2:
    // Initial pressure for fast approach

	
    instTUNE2_PressureOperatorSide.SET_val := 9.0;  // Max pressure
    instTUNE2_PressureOperatorSide.SET := TRUE;
	instTUNE2_PressureOperatorSide();
	
    instTUNE2_PressureDriveSide.SET_val := 9.0;  // Max pressure
    instTUNE2_PressureDriveSide.SET := TRUE;
	instTUNE2_PressureDriveSide();
	
    // Advance solenoid
    riderRollSolenoid1 := FALSE;
    riderRollSolenoid2 := FALSE;

    instTONAdvanceTime.IN := TRUE;

    // When timer finishes, go to work mode
    IF instTONAdvanceTime.Q THEN
	
        instTONAdvanceTime.IN := FALSE;
        riderRollState := 3;  // Enter WORK POSITION
		
    END_IF



//------------------------------------------------------------------
// 3: GO TO WORK POSITION - PRESSURE START VALUE
//------------------------------------------------------------------
3:

	instTUNE2_PressureOperatorSide.SET_val := 0.5;
	instTUNE2_PressureOperatorSide.SET := TRUE;
	instTUNE2_PressureOperatorSide();
		
	instTUNE2_PressureDriveSide.SET_val := 0.5;
	instTUNE2_PressureDriveSide.SET := TRUE;
	instTUNE2_PressureDriveSide();

		
    // Solenoid keeps rider roll engaged
    riderRollSolenoid1 := FALSE;
    riderRollSolenoid2 := FALSE;

	//Wait for command
	riderRollState := 0;


END_CASE



//==============================================================
// Timers execution
//==============================================================
instTONAdvanceTime(PT := machineConfig.winderRiderRollAdvTime);


//==============================================================
// Operator side pressure PID (offset tuning)
//==============================================================
instTUNE2_PressureOperatorSide(
    SU      := pressureOperatorSideIncCmd,
    SD      := pressureOperatorSideDecCmd,
	SET 	:= FALSE,
    SS      := 0.1,
    FS      := 1.0,
    LIMIT_L := 0.0,
    LIMIT_H := 9.0,
    Y       => pressureOperatorSideControllerOutput);


//==============================================================
// Drive side pressure PID
//==============================================================
instTUNE2_PressureDriveSide(
    SU      := pressureDriveSideIncCmd,
    SD      := pressureDriveSideDecCmd,
	SET 	:= FALSE,
    SS      := 0.1,
    FS      := 1.0,
    LIMIT_L := 0.0,
    LIMIT_H := 9.0,
    Y       => pressureDriveSideControllerOutput);
	
	
	   
	pressureSetpointOperatorSide := pressureOperatorSideControllerOutput;
    pressureSetpointDriveSide    := pressureDriveSideControllerOutput;

]]></ST>
      </Implementation>
    </Method>
