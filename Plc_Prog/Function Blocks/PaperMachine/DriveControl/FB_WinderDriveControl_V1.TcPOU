<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="FB_WinderDriveControl_V1" Id="{447ac5fb-7491-43ef-ae65-ceec7a8f52a4}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_WinderDriveControl_V1
VAR_INPUT

    //==============================================================
    // GROUP INTERLOCKS & COMMANDS
    //==============================================================
    startGroup              : BOOL;  // EN: Start command (pulse) / PT: Comando de partida (pulso)
    stopGroup               : BOOL;  // EN: Stop command (maintained) / PT: Comando de parada (nível)
    groupReset              : BOOL;  // EN: Reset all group faults / PT: Reset geral de falhas do grupo
    
    disableGroup            : BOOL;  // EN: Disable the group operation / PT: Desabilitar operação do grupo

	enableTorqueControl		: BOOL;
	
	
	
    //==============================================================
    // SPEED OFFSET / MANUAL ADJUSTMENTS
    //==============================================================
    grouSpeedDifIncCmd      : BOOL;  // EN: Increase speed offset / PT: Aumenta o offset de velocidade
    grouSpeedDifDecCmd      : BOOL;  // EN: Decrease speed offset / PT: Reduz o offset de velocidade
    groupRecoverSpeedCmd    : BOOL;  // EN: Recover nominal speed while TRUE / PT: Recupera velocidade nominal enquanto TRUE

    // Pressure fine adjustments for rider roll
    pressureOperatorSideIncCmd : BOOL; // EN: Increase operator-side pressure / PT: Aumenta a pressão no lado do operador
    pressureOperatorSideDecCmd : BOOL; // EN: Decrease operator-side pressure / PT: Diminui a pressão no lado do operador

    pressureDriveSideIncCmd    : BOOL; // EN: Increase drive-side pressure / PT: Aumenta a pressão no lado motriz
    pressureDriveSideDecCmd    : BOOL; // EN: Decrease drive-side pressure / PT: Diminui a pressão no lado motriz

	riderRollWorkPositionCmd	: BOOL;
	riderRollReleasePositionCmd	: BOOL;
	
    //==============================================================
    // CORE LOCK (CHUCK LOCKING SYSTEM)
    //==============================================================
    coreLockAutoMan         : BOOL;  // EN: Core lock mode (0=Manual, 1=Auto) / PT: Modo do travamento do mandril (0=Manual, 1=Automático)
    coreLockCmd             : BOOL;  // EN: Lock core chucks / PT: Travar mandril (core chucks)
    coreUnlockCmd           : BOOL;  // EN: Unlock core chucks / PT: Destravar mandril

	//==============================================================
    // CORE LOCK (CHUCK LOCKING SYSTEM)
    //==============================================================
	coreAceleratorEngageCmd : BOOL;
	coreAceleratorDisengageCmd : BOOL;
	coreAceleratorMotorReady : BOOL;
	
    //==============================================================
    // CORE BRAKE CONTROL
    //==============================================================
    coreBrakeAutoMan        : BOOL;  // EN: Core brake mode (0=Manual, 1=Auto) / PT: Modo de freio do mandril (0=Manual, 1=Automático)
    coreBrakeEnableCmd      : BOOL;  // EN: Enable core brake / PT: Habilita o freio do mandril
    coreBrakeDisableCmd     : BOOL;  // EN: Disable core brake / PT: Desabilita o freio do mandril

    //==============================================================
    // DRIVE STATUS INPUTS — MAIN DRIVE
    //==============================================================
    masterReady             : BOOL;  // EN: Master drive ready (no trip) / PT: Drive mestre pronto (sem falha)

    //==============================================================
    // SPEED SETPOINTS & MODE SELECTION
    //==============================================================
    groupAutoSpeedMPM       : REAL;         // EN: Automatic mode line speed [m/min] / PT: Velocidade em modo automático [m/min]
    groupManualSpeedMPM     : REAL := 50.0; // EN: Manual mode line speed [m/min] / PT: Velocidade em modo manual [m/min]
    groupSpeedAutoMan       : BOOL;         // EN: Speed mode (0=Manual, 1=Auto) / PT: Modo de velocidade (0=Manual, 1=Automático)

    //==============================================================
    // SPEED & TORQUE FEEDBACKS — MASTER DRIVE
    //==============================================================
    masterSpeedFeedback     : REAL;  // EN: Actual speed feedback / PT: Velocidade real do drive
    masterTorqueFeedback    : REAL;  // EN: Actual torque feedback / PT: Torque real do drive

    //==============================================================
    // CORE POSITIONING ARM (PICK-UP ROLL)
    //==============================================================
    corePositioningArmFwdCmd      : BOOL;  // EN: Command to move arm forward / PT: Comando para avançar o braço posicionador
    corePositioningArmRevCmd      : BOOL;  // EN: Command to move arm backward / PT: Comando para recuar o braço posicionador

    corePositioningArmPosLimitFwd : BOOL;  // EN: Forward limit switch / PT: Fim de curso avançado
    corePositioningArmPosLimitRev : BOOL;  // EN: Reverse limit switch / PT: Fim de curso recuado

    corePositioningArmFault       : BOOL;  // EN: Positioning arm fault / PT: Falha no braço posicionador

    masterDiameter          : REAL := 263.878; // EN: Master drum diameter [mm] / PT: Diâmetro do rolo mestre [mm]

    //==============================================================
    // MACHINE CONFIGURATION STRUCT
    //==============================================================
    machineConfig : PaperMachine_TypeHmiConfig; // EN: Global HMI configuration / PT: Configuração global da HMI

END_VAR
VAR_OUTPUT

    //==============================================================
    // STATE & DIAGNOSTICS
    //==============================================================
    deviceState             : STRING; // EN: Current device state (text) / PT: Estado atual do grupo (texto)
    groupFault              : BOOL;   // EN: Group fault active / PT: Falha ativa no grupo
    statusCode              : INT;    // EN: 0=Idle, 1=Starting, 2=Running, 3=Fault / PT: 0=Parado, 1=Partindo, 2=Rodando, 3=Falha
	speedDif	: REAL;
    //==============================================================
    // DRIVE SPEED REFERENCES (RPM)
    //==============================================================
    masterSpeedSetpointRPM  : REAL;   // EN: Drive speed reference [RPM] / PT: Referência de velocidade do drive [RPM]

    //==============================================================
    // LINE SPEED & TORQUE REFERENCES
    //==============================================================
    nextGroupSpeedRefMPM    : REAL;   // EN: Speed reference for next group [m/min] / PT: Velocidade sugerida para o próximo grupo [m/min]

    //==============================================================
    // DRIVE ENABLE & RESET COMMANDS
    //==============================================================
    masterEnable            : BOOL;   // EN: Enable master drive / PT: Habilita o drive mestre

    //==============================================================
    // CORE POSITIONING ARM OUTPUTS
    //==============================================================
    corePositioningArmFwd   : BOOL;   // EN: Move arm forward / PT: Avançar braço posicionador
    corePositioningArmRev   : BOOL;   // EN: Move arm backward / PT: Recuar braço posicionador
	coreLockSolenoid		: BOOL;
	
	//==============================================================
    // CORE LOCK (CHUCK LOCKING SYSTEM)
    //==============================================================
	coreAceleratorEngageSolenoid : BOOL;
	coreAceleratorMotorStart 	: BOOL;	
	coreAceleratorMotorReset 	: BOOL;	
	
    //==============================================================
    // CORE BRAKE / LOCK OUTPUTS
    //==============================================================
    coreBrakeEnableSolenoid     : BOOL; // EN: Core brake solenoid 1 / PT: Solenóide do freio do mandril 1
    coreBrakeEnableSolenoid2    : BOOL; // EN: Core brake solenoid 2 / PT: Solenóide do freio do mandril 2

    //==============================================================
    // RIDER ROLL CONTROL (PRESSURE)
    //==============================================================
     riderRollSolenoid1               : BOOL; // EN: Rider roll engagement solenoid / PT: Solenóide de engate do rider roll
	 riderRollSolenoid2               : BOOL; // EN: Rider roll engagement solenoid / PT: Solenóide de engate do rider roll
 
   	pressureOperatorSideControllerOutput : REAL; // EN: Controller output (operator side) / PT: Saída do controlador (lado operador)
    pressureDriveSideControllerOutput    : REAL; // EN: Controller output (drive side) / PT: Saída do controlador (lado motriz)
   
	pressureSetpointOperatorSide : REAL; // EN: Controller output (operator side) / PT: Saída do controlador (lado operador)
    pressureSetpointDriveSide    : REAL; // EN: Controller output (drive side) / PT: Saída do controlador (lado motriz)

    //==============================================================
    // FEEDBACKS (LINE SPEED / TORQUE)
    //==============================================================
    upperMasterSpeedMPM      : REAL;  // EN: Line speed feedback [m/min] / PT: Velocidade de linha [m/min]
    upperMasterTorque        : REAL;  // EN: Master torque feedback / PT: Torque do mestre

    //==============================================================
    // HMI ALARMS STRUCT
    //==============================================================
    hmiAlarms                : PaperMachine_TypeHmiAlarms; // EN: Alarm structure / PT: Estrutura de alarmes

END_VAR

VAR
    //==============================================================
    // INTERNAL FUNCTION BLOCK INSTANCES
    //==============================================================
    instFB_GroupDriveControl_V1       : FB_GroupDriveControl_V1;  // EN: Core group logic / PT: Lógica principal do grupo
    instFB_GroupSpeedControl_V1       : FB_GroupSpeedControl_V1;  // EN: Speed regulation / PT: Controle de velocidade

    instFB_WinderSpeedControl       : FB_WinderSpeedControl;  // EN: Speed regulation / PT: Controle de velocidade

	
    instFB_GroupDisplayFilters_V1     : FB_GroupDisplayFilters_V1; // EN: Filters for HMI visualization / PT: Filtros de exibição para HMI


	instTONAdvanceTime: TON;
	rRiderRollWorkPositionCmd: BOOL;
	riderRollWorkPositionCmdOld: BOOL;
	rRiderRollReleasePositionCmd: BOOL;
	riderRollReleasePositionCmdOld: BOOL;
	instTONCoreAceleratorReturnTime: TON;
	
	operatorSideLastePressure : REAL;
	driveSideLastePressure : REAL;

	
	instTONCoreBrakeMaxTime: TON;
END_VAR

VAR PERSISTENT
	
	riderRollState	: INT;
    instTUNE2_PressureOperatorSide : TUNE2; // EN: PID for operator-side pressure / PT: PID da pressão lado operador
    instTUNE2_PressureDriveSide    : TUNE2; // EN: PID for drive-side pressure / PT: PID da pressão lado motriz

END_VAR

VAR_IN_OUT
	
	torqueSetpoint	: REAL;

END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[// ─────────────────────────────────────────────────────────────────────────────
// MAIN CALL SEQUENCE
// ─────────────────────────────────────────────────────────────────────────────

_GroupControl();          // 1) State machine: edges, enables, stop modes

_alarmsDisplay();

_auxiliaryControls();
_CoreAceleratorControl();
_coreBrakeControl();
_coreLock();
_riderRollControl();]]></ST>
    </Implementation>
    <Method Name="_alarmsDisplay" Id="{58318012-a206-4cc5-92b9-cae5e8ca60e4}">
      <Declaration><![CDATA[METHOD _alarmsDisplay
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="_auxiliaryControls" Id="{ad191cf7-38cc-4986-a9ae-6e0815328245}">
      <Declaration><![CDATA[METHOD _auxiliaryControls
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
//==============================================
// PICK-UP ROLL POSITIONER
//  - Uses: pickUpRollPosCmdFwd / pickUpRollPosCmdRev
//  - Safety: fault or limit reached → stop
//  - Safety (optional): if both cmds = TRUE, stop
//==============================================
IF NOT corePositioningArmFault THEN
    // Forward
    IF corePositioningArmFwdCmd
       AND NOT corePositioningArmRevCmd
       AND NOT corePositioningArmPosLimitFwd THEN
        // EN: run forward / PT: avança
        corePositioningArmFwd := TRUE;
    ELSE
        corePositioningArmFwd := FALSE;
    END_IF;

    // Reverse
    IF corePositioningArmRevCmd
       AND NOT corePositioningArmFwdCmd
       AND NOT corePositioningArmPosLimitRev THEN
        // EN: run reverse / PT: recua
        corePositioningArmRev := TRUE;
    ELSE
        corePositioningArmRev := FALSE;
    END_IF;
ELSE
    // EN: Fault → stop / PT: Falha → para
    corePositioningArmFwd := FALSE;
    corePositioningArmRev := FALSE;
END_IF;




]]></ST>
      </Implementation>
    </Method>
    <Method Name="_CoreAceleratorControl" Id="{2119907f-2c06-415b-92fb-14af1a19ac09}">
      <Declaration><![CDATA[METHOD _CoreAceleratorControl
VAR_INPUT
END_VAR
(*


	//==============================================================
    // CORE LOCK (CHUCK LOCKING SYSTEM)
    //==============================================================
	coreAceleratorEngageSolenoid : BOOL;
	coreAceleratorMotorStart 	: BOOL;	
	coreAceleratorMotorReset 	: BOOL;	
	
		//==============================================================
    // CORE LOCK (CHUCK LOCKING SYSTEM)
    //==============================================================
	coreAceleratorEngageCmd : BOOL;
	coreAceleratorDisengageCmd : BOOL;
	coreAceleratorMotorReady : BOOL;

*)]]></Declaration>
      <Implementation>
        <ST><![CDATA[

//IF NOT coreAceleratorMotorReady THEN
	
	IF coreAceleratorEngageCmd AND NOT coreAceleratorDisengageCmd THEN
		
		instTONCoreAceleratorReturnTime.IN := TRUE;
		coreAceleratorEngageSolenoid := TRUE;
		coreAceleratorMotorStart := TRUE;
	
	END_IF
	
	
	
	IF (coreAceleratorDisengageCmd AND NOT coreAceleratorEngageCmd) OR instTONCoreAceleratorReturnTime.Q THEN
		
		instTONCoreAceleratorReturnTime.IN := FALSE;
		coreAceleratorEngageSolenoid := FALSE;	
		coreAceleratorMotorStart := FALSE;
		
	
	END_IF
	
//END_IF



instTONCoreAceleratorReturnTime(PT := T#30S);]]></ST>
      </Implementation>
    </Method>
    <Method Name="_coreBrakeControl" Id="{9a1a8d61-d66e-4d8e-bb72-332626f42901}">
      <Declaration><![CDATA[METHOD _coreBrakeControl
]]></Declaration>
      <Implementation>
        <ST><![CDATA[ 

IF coreBrakeEnableCmd AND NOT coreBrakeDisableCmd THEN
	
	coreBrakeEnableSolenoid := TRUE;
	instTONCoreBrakeMaxTime.IN := TRUE;	
	
END_IF

IF (coreBrakeDisableCmd AND NOT coreBrakeEnableCmd) OR instTONCoreBrakeMaxTime.Q  THEN
	
	coreBrakeEnableSolenoid := FALSE;
	instTONCoreBrakeMaxTime.IN := FALSE;	
	

END_IF


instTONCoreBrakeMaxTime(PT := T#10S);]]></ST>
      </Implementation>
    </Method>
    <Method Name="_coreLock" Id="{a30ac320-9842-4fa7-9f3b-c311da26001b}">
      <Declaration><![CDATA[METHOD _coreLock
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF corePositioningArmPosLimitFwd OR corePositioningArmPosLimitRev THEN
	
	IF coreLockCmd AND NOT coreUnlockCmd THEN
		
		coreLockSolenoid := TRUE;
	
	END_IF
	
	IF coreUnlockCmd AND NOT coreLockCmd THEN
		
		coreLockSolenoid := FALSE;

	END_IF

END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="_GroupControl" Id="{da0d122d-4714-41f7-b8d9-310e14ed1d86}">
      <Declaration><![CDATA[METHOD _GroupControl
VAR_INPUT
END_VAR
(*
FUNCTION_BLOCK FB_DryingSectionDriveControl_V3
VAR_INPUT

    //==============================================================
    // GROUP INTERLOCKS & COMMANDS
    //==============================================================
    startGroup              : BOOL;  // EN: Start command (pulse) / PT: Comando de partida (pulso)
    stopGroup               : BOOL;  // EN: Stop command (level) / PT: Comando de parada (nível)
    groupReset              : BOOL;  // EN: Reset group faults / PT: Reset de falhas do grupo

    //==============================================================
    // SPEED OFFSET / MANUAL ADJUSTMENTS
    //==============================================================
    grouSpeedDifIncCmd      : BOOL;  // EN: Lamp or indication – speed offset increasing / PT: Lâmpada ou indicação – offset de velocidade aumentando
    grouSpeedDifDecCmd      : BOOL;  // EN: Lamp or indication – speed offset decreasing / PT: Lâmpada ou indicação – offset de velocidade reduzindo
    groupRecoverSpeedCmd    : BOOL;  // EN: Recover nominal speed while TRUE / PT: Recuperar velocidade nominal enquanto TRUE

    //==============================================================
    // DRIVE STATUS INPUTS — UPPER GROUP
    //==============================================================
    upperMasterReady        : BOOL;  // EN: Upper master ready (no trip) / PT: Mestre superior pronto (sem falha)
    upperSlave1Ready        : BOOL;  // EN: Upper slave 1 ready / PT: Escravo 1 superior pronto

    //==============================================================
    // DRIVE STATUS INPUTS — LOWER GROUP
    //==============================================================
    lowerMasterReady        : BOOL;  // EN: Lower master ready (no trip) / PT: Mestre inferior pronto (sem falha)
    lowerSlave1Ready        : BOOL;  // EN: Lower slave 1 ready / PT: Escravo 1 inferior pronto

    //==============================================================
    // SPEED SETPOINTS & MODE SELECTION
    //==============================================================
    groupAutoSpeedMPM       : REAL;        // EN: Automatic mode speed [m/min] / PT: Velocidade em modo automático [m/min]
    groupManualSpeedMPM     : REAL := 50.0;// EN: Manual mode speed [m/min] / PT: Velocidade em modo manual [m/min]
    groupSpeedAutoMan       : BOOL;        // EN: Speed mode (0=Manual, 1=Auto) / PT: Modo de velocidade (0=Manual, 1=Automático)

    //==============================================================
    // SPEED & TORQUE FEEDBACKS — UPPER GROUP
    //==============================================================
    upperMasterSpeedFeedback    : REAL;  // [m/min or %]
    upperMasterTorqueFeedback   : REAL;  // [% or Nm]
    upperSlave1SpeedFeedback    : REAL;
    upperSlave1TorqueFeedback   : REAL;

    //==============================================================
    // SPEED & TORQUE FEEDBACKS — LOWER GROUP
    //==============================================================
    lowerMasterSpeedFeedback    : REAL;
    lowerMasterTorqueFeedback   : REAL;
    lowerSlave1SpeedFeedback    : REAL;
    lowerSlave1TorqueFeedback   : REAL;

    //==============================================================
    // COOLING MOTOR FAULT INPUTS
    //==============================================================
    upperMasterCoolingMotorFault : BOOL;  // EN: Upper master cooling motor fault / PT: Falha no motor de ventilação do mestre superior
    upperSlave1CoolingMotorFault : BOOL;  // EN: Upper slave 1 cooling motor fault / PT: Falha no motor de ventilação do escravo 1 superior
    lowerMasterCoolingMotorFault : BOOL;  // EN: Lower master cooling motor fault / PT: Falha no motor de ventilação do mestre inferior
    lowerSlave1CoolingMotorFault : BOOL;  // EN: Lower slave 1 cooling motor fault / PT: Falha no motor de ventilação do escravo 1 inferior

    //==============================================================
    // FABRIC / WIRE STRETCHER ACTUATORS
    //==============================================================
    upperDryingSectionFabricStretchCmd     : BOOL;  // EN: Command to stretch upper fabric / PT: Comando para esticar a tela superior
    upperDryingSectionFabricUnstretchCmd   : BOOL;  // EN: Command to loosen upper fabric / PT: Comando para afrouxar a tela superior
    lowerDryingSectionFabricStretchCmd     : BOOL;  // EN: Command to stretch lower fabric / PT: Comando para esticar a tela inferior
    lowerDryingSectionFabricUnstretchCmd   : BOOL;  // EN: Command to loosen lower fabric / PT: Comando para afrouxar a tela inferior
    upperDryingSectionFabricStretcherMotorFault : BOOL;  // EN: Upper stretcher motor fault / PT: Falha no motor de estiramento superior
    lowerDryingSectionFabricStretcherMotorFault : BOOL;  // EN: Lower stretcher motor fault / PT: Falha no motor de estiramento inferior

    //==============================================================
    // FABRIC / WIRE OVERRUN SENSORS
    //==============================================================
    upperDryingSectionFabricOverrunOperatorSideSensor : BOOL; // EN: Upper fabric overrun sensor (operator side) / PT: Sensor de sobrecurso da tela superior (lado operador)
    upperDryingSectionFabricOverrunDriveSideSensor    : BOOL; // EN: Upper fabric overrun sensor (drive side) / PT: Sensor de sobrecurso da tela superior (lado acionamento)
    lowerDryingSectionFabricOverrunOperatorSideSensor : BOOL; // EN: Lower fabric overrun sensor (operator side) / PT: Sensor de sobrecurso da tela inferior (lado operador)
    lowerDryingSectionFabricOverrunDriveSideSensor    : BOOL; // EN: Lower fabric overrun sensor (drive side) / PT: Sensor de sobrecurso da tela inferior (lado acionamento)

    //==============================================================
    // PICK-UP ROLL POSITIONER
    //==============================================================
    pickUpRollPosCmdFwd       : BOOL;  // EN: Command forward / PT: Avanço do rolo pick-up
    pickUpRollPosCmdRev       : BOOL;  // EN: Command reverse / PT: Recuo do rolo pick-up
    pickUpRollPosLimitFwd     : BOOL;  // EN: Forward limit switch / PT: Fim de curso frontal
    pickUpRollPosLimitRev     : BOOL;  // EN: Reverse limit switch / PT: Fim de curso traseiro
    pickUpRollPosFault        : BOOL;  // EN: Positioner fault / PT: Falha no posicionador

    //==============================================================
    // SCRAPER OSCILLATORS
    //==============================================================
    babyDryerScraperOscCmd     : BOOL;  // EN: Command to start Baby Dryer scraper oscillator / PT: Comando para iniciar oscilador do Baby Dryer
    babyDryerScraperOscFault   : BOOL;  // EN: Baby Dryer oscillator fault / PT: Falha no oscilador do Baby Dryer
    babyDryerScraperOscRunning : BOOL;  // EN: Baby Dryer oscillator running / PT: Oscilador do Baby Dryer em operação

    upperGroupScraperOscCmd     : BOOL;  // EN: Upper group scraper oscillator command / PT: Comando de oscilação da raspa do grupo superior
    upperGroupScraperOscFault   : BOOL;  // EN: Upper group oscillator fault / PT: Falha no oscilador do grupo superior
    upperGroupScraperOscRunning : BOOL;  // EN: Upper group oscillator running / PT: Oscilador do grupo superior em operação

    lowerGroupScraperOscCmd     : BOOL;  // EN: Lower group scraper oscillator command / PT: Comando de oscilação da raspa do grupo inferior
    lowerGroupScraperOscFault   : BOOL;  // EN: Lower group oscillator fault / PT: Falha no oscilador do grupo inferior
    lowerGroupScraperOscRunning : BOOL;  // EN: Lower group oscillator running / PT: Oscilador do grupo inferior em operação

    //==============================================================
    // STEAM PRESSURE CONTROL (PID)
    //==============================================================
    steamPressureAutoMan        : BOOL;  // EN: Steam pressure mode (0=Manual, 1=Auto) / PT: Modo de pressão do vapor (0=Manual, 1=Automático)
    steamPressureAutoSetpoint   : REAL;  // EN: Auto mode setpoint [bar] / PT: Setpoint em modo automático [bar]
    steamPressureManualSetpoint : REAL;  // EN: Manual mode setpoint [bar] / PT: Setpoint em modo manual [bar]
    steamPressureFeedback       : REAL;  // EN: Steam pressure feedback [bar] / PT: Retorno de pressão do vapor [bar]
    steamPressureKp             : REAL := 1.0;  // EN: PID proportional gain / PT: Ganho proporcional do PID
    steamPressureTn             : REAL := 8.0;  // EN: PID integral time [s] / PT: Tempo integral do PID [s]
    steamPressureTv             : REAL := 0.0;  // EN: PID derivative time [s] / PT: Tempo derivativo do PID [s]

    //==============================================================
    // MACHINE CONFIGURATION STRUCT
    //==============================================================
    machineConfig               : PaperMachine_TypeHmiConfig; // EN: HMI configuration structure / PT: Estrutura de configuração da HMI

END_VAR
	winderDiameter	: REAL := 800.9;
	winderMotorRPM	: REAL := 212.5; //Motor RPM  / Rel. Mecanicia (1700 / 8)
	


VAR_OUTPUT

    //==============================================================
    // STATE & DIAGNOSTICS
    //==============================================================
    deviceState                 : STRING;  // EN: Current readable device state / PT: Estado textual atual do grupo
    groupFault                  : BOOL;    // EN: Group fault active / PT: Falha ativa no grupo
    statusCode                  : INT;     // EN: 0=Idle, 1=Starting, 2=Running, 3=Fault / PT: 0=Parado, 1=Partindo, 2=Rodando, 3=Falha

    //==============================================================
    // DRIVE SPEED REFERENCES (RPM)
    //==============================================================
    upperMasterSpeedSetpointRPM : REAL;
    upperSlaveSpeedSetpointRPM  : REAL;
    lowerMasterSpeedSetpointRPM : REAL;
    lowerSlaveSpeedSetpointRPM  : REAL;


    //==============================================================
    // LINE SPEED & TORQUE REFERENCES
    //==============================================================
    nextGroupSpeedRefMPM        : REAL;  // EN: Suggested next group speed [m/min] / PT: Velocidade sugerida para o próximo grupo [m/min]

    upperSlave1TorqueRefPct     : REAL;
    upperSlave2TorqueRefPct     : REAL;
    lowerSlave1TorqueRefPct     : REAL;
    lowerSlave2TorqueRefPct     : REAL;

    //==============================================================
    // DRIVE ENABLE & RESET COMMANDS
    //==============================================================
    upperMasterEnable           : BOOL;
    upperSlave1Enable           : BOOL;
    upperMasterReset            : BOOL;
    upperSlave1Reset            : BOOL;

    lowerMasterEnable           : BOOL;
    lowerSlave1Enable           : BOOL;
    lowerMasterReset            : BOOL;
    lowerSlave1Reset            : BOOL;

    //==============================================================
    // FABRIC / WIRE STRETCHERS
    //==============================================================
    upperDryingSectionFabricStretch   : BOOL;
    upperDryingSectionFabricUnstretch : BOOL;
    lowerDryingSectionFabricStretch   : BOOL;
    lowerDryingSectionFabricUnstretch : BOOL;

    //==============================================================
    // PICK-UP ROLL POSITIONER OUTPUTS
    //==============================================================
    pickUpRollPosRunFwd          : BOOL;
    pickUpRollPosRunRev          : BOOL;

    //==============================================================
    // SCRAPER OSCILLATORS OUTPUTS
    //==============================================================
    babyDryerScraperOscRun       : BOOL;
    upperGroupScraperOscRun      : BOOL;
    lowerGroupScraperOscRun      : BOOL;

    //==============================================================
    // STEAM PRESSURE PID OUTPUT
    //==============================================================
    steamPressureControllerOutput : REAL;

    //==============================================================
    //FEEDBACKS (MPM / RPM / TOQUE)
    //==============================================================
    upperMasterSpeedMPM          : REAL;
    upperSlave1SpeedMPM          : REAL;
    lowerMasterSpeedMPM          : REAL;
    lowerSlave1SpeedMPM          : REAL;

    upperMasterSpeedRPM          : REAL;
    upperSlave1SpeedRPM          : REAL;
    lowerMasterSpeedRPM          : REAL;
    lowerSlave1SpeedRPM          : REAL;
	
    upperMasterTorque          	: REAL;
    upperSlave1Torqu          	: REAL;
    lowerMasterTorque          	: REAL;
    lowerSlave1Torque          	: REAL;

    //==============================================================
    // HMI ALARMS STRUCT
    //==============================================================
    hmiAlarms                    : PaperMachine_TypeHmiAlarms;

END_VAR



VAR
    //==============================================================
    // INTERNAL FUNCTION BLOCK INSTANCES
    //==============================================================
    instFB_GroupDriveControl_V1       : FB_GroupDriveControl_V1;
    instFB_GroupSpeedControl_V1       : FB_GroupSpeedControl_V1;
    instFB_GroupDisplayFilters_V1     : FB_GroupDisplayFilters_V1;
    instFB_GroupTorqueTrimControl_V1  : FB_GroupTorqueTrimControl_V1;
    instCTRL_PID_TemperatureController: CTRL_PID;

END_VAR



