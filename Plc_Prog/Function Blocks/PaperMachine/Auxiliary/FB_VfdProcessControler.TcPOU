<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="FB_VfdProcessControler" Id="{8740e75f-d34c-4ff2-83ed-752cec9cc5d2}" SpecialFunc="None">
    <Declaration><![CDATA[(*
    FB_ProcessControler
    Purpose: Generic process controller with start/stop latch, status codes,
             PID (OSCAT CTRL_PID), optional reverse action, PV PT1 filter,
             engineering↔% scaling, drive run supervision, and HMI displays.

    Sequence: Start pulse toggles RUN latch; Stop pulse/level forces stop.

    Status codes: statusCode INT → 0=Idle, 1=Running, 2=Fault

    Notes: Includes optional low/high PV “hold” with hysteresis (normal-stop class).
*)

FUNCTION_BLOCK FB_VfdProcessControler
VAR_INPUT
    // ===== Sequence commands =====
    startCommand                 : BOOL;            // Start pulse toggles RUN latch
    stopCommand                  : BOOL;            // Stop pulse/level forces stop

    // ===== Manual output & Auto SP nudge =====
    processSetpointManInc        : BOOL;            // Manual output ↑ (0..100%)
    processSetpointManDec        : BOOL;            // Manual output ↓ (0..100%)
    processSetpointManSteps      : REAL := 0.1;

    processSetpointAutoInc       : BOOL;            // Auto SP ↑ (engineering units or %)
    processSetpointAutoDec       : BOOL;            // Auto SP ↓ (engineering units or %)
    processSetpointAutoSteps     : REAL := 1.0;

    // ===== Mode =====
    autoMode                     : BOOL;            // TRUE=Automatic / FALSE=Manual
    reverseActing                : BOOL := FALSE;   // TRUE: higher output decreases PV; FALSE: direct

    // ===== Process signals (PV in engineering units) =====
    processFeedbackEng           : REAL;            // PV (engineering units), e.g., bar/kPa/°C/…

    // ===== PID parameters (OSCAT CTRL_PID) =====
    kp                           : REAL := 1.0;     // Proportional gain (sign handled via reverseActing)
    tn                           : REAL := 8.0;     // Integral time [s]
    tv                           : REAL := 0.0;     // Derivative time [s]

    // ===== Output limits & offset =====
    outLowLimitPct               : REAL := 0.0;     // Min output %
    outHighLimitPct              : REAL := 100.0;   // Max output %
    outputOffsetPct              : REAL := 0.0;     // Offset added to final output

    // ===== PID housekeeping =====
    resetPID                     : BOOL;            // Reset integrator

    // ===== Input filter (OSCAT FT_PT1) =====
    enableInputFilter            : BOOL := TRUE;    // Enable PV PT1 filter
    inputFilterTime              : TIME := T#300ms; // PT1 time constant
    inputFilterGainK             : REAL := 1.0;     // PT1 gain

    displayFilterTime            : TIME := T#20ms;  // Small PT1 for HMI displays

    // ===== Optional scaling (engineering ↔ %) =====
    enableScaling                : BOOL := TRUE;    // Enable engineering↔% scaling
    pLoEng                       : REAL := 0.0;     // Engineering low bound
    pHiEng                       : REAL := 10.0;    // Engineering high bound

    // ===== Drive interface & supervision (VFD or actuator drive) =====
    vfdReady                     : BOOL;            // Drive ready/healthy
    vfdRunFeedback               : BOOL;            // Drive RUN feedback
    vfdFaultFeedback             : BOOL;            // Drive fault
    vfdRunFbTimeout              : TIME := T#5s;    // Timeout to receive RUN FB after start

    // ===== Drive analog feedbacks (for HMI display) =====
    vfdCurrentFeedback           : REAL;            // Current [A or %]
    vfdEngFeedback               : REAL;            // Engineering feedback (e.g., rpm, flow, etc.)
    vfdTorqueFeedback            : REAL;            // Torque (Nm or %)

    // ===== Safety (true safety inputs only) =====
    safetyOk                     : BOOL := TRUE;    // Safety chain OK
    estopOk                      : BOOL := TRUE;    // E-Stop loop OK
    guardClosedOk                : BOOL := TRUE;    // Guards/doors closed

    // ===== Interlocks (process permissives) — normal stop only =====
    interlock1                   : BOOL := TRUE;
    interlock2                   : BOOL := TRUE;
    interlock3                   : BOOL := TRUE;
    interlock4                   : BOOL := TRUE;
    interlock5                   : BOOL := TRUE;
    interlock6                   : BOOL := TRUE;

 // ===== Optional low-PV hold (normal-stop/hold) =====
    minPVEnable                  : BOOL := FALSE;   // Enable low-PV hold
    minPVTripEng                 : REAL := 0.5;     // Trip threshold (engineering units)
    minPVReleaseEng              : REAL := 0.7;     // Release threshold (engineering units)
    minPVTripTime                : TIME := T#1s;    // PV < trip for this long to trip
    minPVReleaseTime             : TIME := T#1s;    // PV > release for this long to release

    // ===== Optional high-PV hold (normal-stop/hold) =====
    maxPVEnable                  : BOOL := FALSE;   // Enable high-PV hold
    maxPVTripEng                 : REAL := 9.5;     // Trip threshold (engineering units)
    maxPVReleaseEng              : REAL := 9.2;     // Release threshold (engineering units)
    maxPVTripTime                : TIME := T#1s;    // PV > trip for this long to trip
    maxPVReleaseTime             : TIME := T#1s;    // PV < release for this long to release
	
	
END_VAR

VAR_OUTPUT
    running                      : BOOL;            // TRUE only during RUN state
    controlOutputPct             : REAL;            // Final control output 0..100%
    pidDiff                      : REAL;            // SET − ACT (post-scaling)
    pidLimited                   : BOOL;            // TRUE if saturated
    deviceState                  : STRING(80);      // Human-readable state
    vfdStartCmdOut               : BOOL;            // Asserted in Start/Run to the drive

    // ===== Holds (normal stop class) =====
    minPressureHoldActive        : BOOL;            // Low-PV hold active
    maxPressureHoldActive        : BOOL;            // High-PV hold active

    // ===== Status & HMI displays =====
    statusCode                   : INT;             // 0=Idle, 1=Running, 2=Fault
    vfdCurrentDisplay            : REAL;            // Display current [A or %]
    vfdTorqueDisplay             : REAL;            // Display torque (Nm or %)
    vfdEngDisplay                : REAL;            // Display engineering feedback (e.g., rpm)
    processFeedbackEngDisplay    : REAL;            // PV (engineering units), e.g., bar/kPa/°C/…
	
	
END_VAR

VAR
    // ===== First scan & state/edges =====
    firstScan                    : BOOL := TRUE;    // TRUE only on first PLC cycle

    step                         : INT;             // 0=Idle,10=Starting,20=Running,90=Stopping
    startOld                     : BOOL;            // Edge memory
    stopOld                      : BOOL;            // Edge memory
    rStart                       : BOOL;            // Rising edge: start
    rStop                        : BOOL;            // Rising edge: stop
    runLatch                     : BOOL;            // Toggled by Start; cleared by Stop

    // ===== Internals =====
    manualCmd                    : REAL;            // Manual command %
    yPID                         : REAL;            // PID output %
    kpUse                        : REAL;            // Kp adjusted by reverseActing

    // ===== Filtered PV (engineering units) =====
    pvEngFiltered                : REAL;

    // ===== PV & SP in % (post-scaling) =====
    pvPct                        : REAL;
    spPct                        : REAL;

    // ===== Timers =====
    tonRunFbWait                 : TON;             // Waits RUN FB after start

    // ===== Low/High PV timers =====
    tonMinPTrip                  : TON;
    tonMinPRelease               : TON;
    tonMaxPTrip                  : TON;
    tonMaxPRelease               : TON;

    // ===== Instances =====
    instPID                      : CTRL_PID;        // OSCAT PID
    instPT1                      : FT_PT1;          // PV PT1 filter

    // ===== Aggregations =====
    allSafetyOK                  : BOOL;            // safetyOk & estopOk & guardClosedOk
    anyInterlockOpen             : BOOL;            // any interlock is FALSE

    // ===== HMI display filters =====
    instPT1_TorqueDisplay        : FT_PT1;          // PT1 for torque display
    instPT1_SpeedDisplay         : FT_PT1;          // PT1 for engineering display
    instPT1_ProcessFeedbackEngDisplay        : FT_PT1;          // PT1 for engineering display
	

    processSetpointManOld        : REAL;            // Last observed manual SP (HMI)
    processSetpointAutoOld       : REAL;            // Last observed auto SP (HMI)
	minPVHoldActive: BOOL;
	maxPVHoldActive: BOOL;
END_VAR

VAR PERSISTENT
    instTUNE2AutoSetpoint        : TUNE2;           // OSCAT TUNE2 for auto SP nudge
    instTUNE2ManSetpoint         : TUNE2;           // OSCAT TUNE2 for manual output
END_VAR

VAR_IN_OUT
    // ===== Exposed setpoints =====
    processSetpointMan           : REAL;            // Manual output 0..100%
    processSetpointAuto          : REAL;            // Auto SP (engineering units or % per configuration)
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[// ============================ INITIALIZATION ============================
// Run this block only once on first cycle
IF firstScan THEN
    firstScan := FALSE;

    processSetpointMan      := instTUNE2ManSetpoint.Y;
    processSetpointManOld   := processSetpointMan;

    processSetpointAuto     := instTUNE2AutoSetpoint.Y;
    processSetpointAutoOld  := processSetpointAuto;
END_IF;


// ============================ Edges ============================
rStart := startCommand AND NOT startOld;
startOld := startCommand;

rStop  := stopCommand AND NOT stopOld;
stopOld := stopCommand;

// Start toggles run; Stop forces stop
IF rStart THEN
    runLatch := TRUE;
END_IF;
IF rStop OR stopCommand THEN
    runLatch := FALSE;
END_IF;


// ============================ Aggregations =====================
allSafetyOK := safetyOk AND estopOk AND guardClosedOk;
anyInterlockOpen := NOT (interlock1 AND interlock2 AND interlock3 AND interlock4 AND interlock5 AND interlock6);

// Defaults each cycle
vfdStartCmdOut := FALSE;


// ============================ Low/High PV HOLD supervision ============================
// LOW-PV
IF minPVEnable THEN
    tonMinPTrip   (IN := (processFeedbackEng <  minPVTripEng),     PT := minPVTripTime);
    tonMinPRelease(IN := (processFeedbackEng >  minPVReleaseEng),  PT := minPVReleaseTime);
    IF tonMinPTrip.Q    THEN minPVHoldActive := TRUE;  END_IF;
    IF tonMinPRelease.Q THEN minPVHoldActive := FALSE; END_IF;
	
ELSE
    tonMinPTrip(IN := FALSE);
    tonMinPRelease(IN := FALSE);
    minPVHoldActive := FALSE;
END_IF;

// HIGH-PV
IF maxPVEnable THEN
    tonMaxPTrip   (IN := (processFeedbackEng > maxPVTripEng),       PT := maxPVTripTime);
    tonMaxPRelease(IN := (processFeedbackEng < maxPVReleaseEng),    PT := maxPVReleaseTime);
    IF tonMaxPTrip.Q    THEN maxPVHoldActive := TRUE;  END_IF;
    IF tonMaxPRelease.Q THEN maxPVHoldActive := FALSE; END_IF;
	
ELSE
    tonMaxPTrip(IN := FALSE);
    tonMaxPRelease(IN := FALSE);
    maxPVHoldActive := FALSE;
END_IF;


// ============================ Immediate stop / safety/fault =================
IF rStop OR stopCommand THEN
    controlOutputPct := 0.0;
    running := FALSE;
    deviceState := 'Stopping (Stop command)';
    runLatch := FALSE;
    step := 90;
END_IF;

IF vfdFaultFeedback THEN
    deviceState := 'Fault from drive';
    runLatch := FALSE;
    step := 90;
END_IF;

IF NOT allSafetyOK THEN
    deviceState := 'Stopping: safety chain open';
    runLatch := FALSE;
    step := 90;
END_IF;


// ============================ State machine =====================
CASE step OF
    // ------------------------------------------------------------
    0: // Idle
        running := FALSE;
        controlOutputPct := 0.0;
        deviceState := 'Idle';
        vfdStartCmdOut := FALSE;

        // Start request via runLatch (toggled by Start pulse)
        IF runLatch AND NOT stopCommand THEN
            // Safety must be OK; drive must be ready; holds must be clear
            IF NOT allSafetyOK THEN
                deviceState := 'Start blocked: safety not OK';
                runLatch := FALSE;
                step := 0;
            ELSIF NOT vfdReady THEN
                deviceState := 'Start blocked: drive not ready';
                runLatch := FALSE;
                step := 0;
            ELSIF (minPVEnable AND minPVHoldActive) OR (maxPVEnable AND maxPVHoldActive) THEN
                deviceState := 'Start blocked: PV hold active';
                runLatch := FALSE;
                step := 0;
            ELSE
                deviceState := 'Starting';
                vfdStartCmdOut := TRUE;                   // send START to drive
                tonRunFbWait(IN := TRUE, PT := vfdRunFbTimeout);
                step := 10;
            END_IF
        END_IF

    // ------------------------------------------------------------
    10: // Starting (await RUN feedback)
        running := FALSE;
        deviceState := 'Starting (await RUN feedback)';
        vfdStartCmdOut := TRUE;

        // Safety/fault during start => stop
        IF NOT allSafetyOK THEN
            tonRunFbWait(IN := FALSE);
            deviceState := 'Stopping: safety chain open';
            vfdStartCmdOut := FALSE;
            runLatch := FALSE;
            step := 90;

        ELSIF vfdFaultFeedback THEN
            tonRunFbWait(IN := FALSE);
            deviceState := 'Fault from drive';
            vfdStartCmdOut := FALSE;
            runLatch := FALSE;
            step := 90;

        // Interlocks are normal stop only
        ELSIF anyInterlockOpen THEN
            tonRunFbWait(IN := FALSE);
            deviceState := 'Stopping: interlock open';
            vfdStartCmdOut := FALSE;
            runLatch := FALSE;
            step := 90;

        // PV holds => normal stop
        ELSIF (minPVEnable AND minPVHoldActive) OR (maxPVEnable AND maxPVHoldActive) THEN
            tonRunFbWait(IN := FALSE);
            deviceState := 'Stopping: PV hold';
            vfdStartCmdOut := FALSE;
            runLatch := FALSE;
            step := 90;

        // RUN feedback arrived
        ELSIF vfdRunFeedback THEN
            tonRunFbWait(IN := FALSE);
            step := 20;

        // Timeout
        ELSIF tonRunFbWait.Q THEN
            tonRunFbWait(IN := FALSE);
            deviceState := 'Start failed: RUN feedback timeout';
            vfdStartCmdOut := FALSE;
            runLatch := FALSE;
            step := 90;
        END_IF

    // ------------------------------------------------------------
    20: // Running (control loop)
        running := TRUE;               // may be used to release other devices
        deviceState := 'Running';
        vfdStartCmdOut := TRUE;

        // Supervision
        IF NOT allSafetyOK THEN
            deviceState := 'Stopping: safety chain open';
            vfdStartCmdOut := FALSE;
            runLatch := FALSE;
            step := 90;

        ELSIF vfdFaultFeedback THEN
            deviceState := 'Fault from drive';
            vfdStartCmdOut := FALSE;
            runLatch := FALSE;
            step := 90;

        ELSIF NOT vfdReady THEN
            deviceState := 'Stopping: drive not ready';
            vfdStartCmdOut := FALSE;
            runLatch := FALSE;
            step := 90;

        ELSIF NOT vfdRunFeedback THEN
            deviceState := 'Stopping: RUN feedback lost';
            vfdStartCmdOut := FALSE;
            runLatch := FALSE;
            step := 90;

        // Interlocks → normal stop
        ELSIF anyInterlockOpen THEN
            deviceState := 'Stopping: interlock open';
            vfdStartCmdOut := FALSE;
            runLatch := FALSE;
            step := 90;

        // PV holds → normal stop
        ELSIF (minPVEnable AND minPVHoldActive) OR (maxPVEnable AND maxPVHoldActive) THEN
            deviceState := 'Stopping: PV hold';
            vfdStartCmdOut := FALSE;
            runLatch := FALSE;
            step := 90;

        // Start toggled OFF while running => stop
        ELSIF NOT runLatch THEN
            deviceState := 'Stopping (Start toggled off)';
            vfdStartCmdOut := FALSE;
            step := 90;

        ELSE
            // ---- Input filtering (PT1) ----
            IF enableInputFilter THEN
                instPT1(in := processFeedbackEng, T := inputFilterTime, K := inputFilterGainK, out => pvEngFiltered);
            ELSE
                pvEngFiltered := processFeedbackEng;
            END_IF

            // ---- Engineering → % scaling ----
            IF enableScaling THEN
                pvPct := _ScaleToPct(pvEngFiltered,       pLoEng, pHiEng);
                spPct := _ScaleToPct(processSetpointAuto, pLoEng, pHiEng);
            ELSE
                pvPct := pvEngFiltered;        // already %
                spPct := processSetpointAuto;  // already %
            END_IF

            // ---- Manual path and PID with bumpless transfer ----
            manualCmd := LIMIT(0.0, processSetpointMan, 100.0);

            // Reverse/direct action by Kp sign
            IF reverseActing THEN
                kpUse := -ABS(kp);
            ELSE
                kpUse :=  ABS(kp);
            END_IF

            instPID(
                ACT := pvPct,
                SET := spPct,
                M_I := manualCmd,
                MAN := NOT autoMode,
                RST := resetPID,
                KP  := kpUse,
                TN  := tn,
                TV  := tv,
                LL  := outLowLimitPct,
                LH  := outHighLimitPct,
                Y   => yPID,
                DIFF=> pidDiff,
                LIM => pidLimited
            );

            // Mode select, offset, clamp
            IF autoMode THEN
                controlOutputPct := yPID;
            ELSE
                controlOutputPct := manualCmd;
            END_IF
            controlOutputPct := LIMIT(outLowLimitPct, controlOutputPct + outputOffsetPct, outHighLimitPct);
        END_IF

    // ------------------------------------------------------------
    90: // Stopping (normal, de-energize)
        running := FALSE;
        controlOutputPct := 0.0;
        vfdStartCmdOut := FALSE;
        tonRunFbWait(IN := FALSE);

        // Return to Idle once stop released and safety OK
        IF NOT stopCommand AND allSafetyOK THEN
            deviceState := 'Idle';
            step := 0;
        END_IF

    // ------------------------------------------------------------
    ELSE
        running := FALSE;
        controlOutputPct := 0.0;
        deviceState := 'Idle';
        vfdStartCmdOut := FALSE;
        step := 0;
END_CASE;


// =============================== Status code ===============================
IF vfdFaultFeedback THEN
    statusCode := 2;             // Fault
ELSIF running THEN
    statusCode := 1;             // Running
ELSE
    statusCode := 0;             // Idle
END_IF

// HMI feedbacks & status (encapsulates PT1 displays and status code if desired)
_FeedbackDisplay();

// Setpoint input handling (encapsulates TUNE2-based HMI writes & nudges)
_SetpointInputControl();
]]></ST>
    </Implementation>
    <Method Name="_FeedbackDisplay" Id="{f09c24d5-9a04-4efe-9848-4f041d614172}">
      <Declaration><![CDATA[METHOD _FeedbackDisplay
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// 5) HMI DISPLAY SIGNALS (filtered speeds/torques + GROUP status)
instPT1_SpeedDisplay(in := vfdEngFeedback, T := displayFilterTime, K := 1.0, out => vfdEngDisplay);
instPT1_TorqueDisplay (in := vfdTorqueFeedback , T := displayFilterTime, K := 1.0, out => vfdTorqueDisplay);
instPT1_ProcessFeedbackEngDisplay(in := processFeedbackEng , T := displayFilterTime, K := 1.0, out => processFeedbackEngDisplay);]]></ST>
      </Implementation>
    </Method>
    <Method Name="_ScaleToPct" Id="{88aec74e-5788-483e-b125-ca692206fd3d}">
      <Declaration><![CDATA[// ============================ Helper ============================
METHOD PRIVATE _ScaleToPct : REAL
VAR_INPUT
    xEng  : REAL;  // value in engineering units
    loEng : REAL;  // min eng
    hiEng : REAL;  // max eng
END_VAR
VAR
    span : REAL;
    pct  : REAL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
span := hiEng - loEng;
IF span = 0.0 THEN
    _ScaleToPct := 0.0; // avoid div by zero
ELSE
    pct := (xEng - loEng) / span * 100.0;
    _ScaleToPct := LIMIT(0.0, pct, 100.0);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="_SetpointInputControl" Id="{72b3042c-379f-48b7-8b1a-d16b04304883}">
      <Declaration><![CDATA[// ============================================================================
// METHOD: _SetpointInputControl
// Purpose: Handle HMI writes for manual output using OSCAT TUNE2. Any external
//          write to manualOutputPct bigger than the configured step will pulse
//          SET for one scan. No SU/SD buttons here (PressureCtrl doesn’t use them).
// Objetivo: Tratar escrita da HMI no manualOutputPct via TUNE2. Mudança externa
//           > passo gera pulso SET de 1 varredura. Sem botões ↑/↓ neste FB.
// ============================================================================
METHOD PRIVATE _SetpointInputControl
VAR
    spManClamped : REAL;
    spAutoClamped : REAL;
	
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Detect external write (> step): ignore tiny jitter
IF ABS(processSetpointMan - processSetpointManOld) > instTUNE2ManSetpoint.SS THEN
    // Clamp to output limits before writing (garante limites)
    spManClamped := LIMIT(outLowLimitPct, processSetpointMan, outHighLimitPct);

    // One-scan SET pulse into TUNE2 (pulso SET de 1 ciclo)
    instTUNE2ManSetpoint(
        SET_val := spManClamped,
        SET     := TRUE
    );
    instTUNE2ManSetpoint(SET := FALSE);

    // Remember applied value (memoriza)
    processSetpointManOld := processSetpointMan;
ELSE
    // Track last seen to avoid drift (rastreia último observado)
    processSetpointManOld := processSetpointMan;
END_IF;

// Keep TUNE2 active (no SU/SD in this FB)
instTUNE2ManSetpoint(
    SET      := FALSE,
    SU       := processSetpointManInc,
    SD       := processSetpointManDec,
    RST      := FALSE,
    SS       := 0.1,           // step reference (passo de referência)
    FS       := 0.0,                     // unused
    LIMIT_L  := outLowLimitPct,
    LIMIT_H  := outHighLimitPct,
    Y        => processSetpointMan
);




// Detect external write (> step): ignore tiny jitter
IF ABS(processSetpointAuto - processSetpointAutoOld) > instTUNE2AutoSetpoint.SS THEN
    // Clamp to output limits before writing (garante limites)
    spAutoClamped := LIMIT(0, processSetpointAuto, 100);

    // One-scan SET pulse into TUNE2 (pulso SET de 1 ciclo)
    instTUNE2AutoSetpoint(
        SET_val := spAutoClamped,
        SET     := TRUE
    );
    instTUNE2AutoSetpoint(SET := FALSE);

    // Remember applied value (memoriza)
    processSetpointAutoOld := processSetpointAuto;
ELSE
    // Track last seen to avoid drift (rastreia último observado)
    processSetpointAutoOld := processSetpointAuto;
END_IF;

// Keep TUNE2 active (no SU/SD in this FB)
instTUNE2AutoSetpoint(
    SET      := FALSE,
    SU       := processSetpointAutoInc,
    SD       := processSetpointAutoDec,
    RST      := FALSE,
    SS       := 0.1,           // step reference (passo de referência)
    FS       := 0.0,                     // unused
    LIMIT_L  := 0.0,
    LIMIT_H  := 100.0,
    Y        => processSetpointAuto
);


]]></ST>
      </Implementation>
    </Method>
    <LineIds Name="FB_VfdProcessControler">
      <LineId Id="6767" Count="43" />
      <LineId Id="7075" Count="0" />
      <LineId Id="6811" Count="11" />
