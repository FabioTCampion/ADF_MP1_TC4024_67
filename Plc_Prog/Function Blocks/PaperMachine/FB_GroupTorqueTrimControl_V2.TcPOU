      <LineId Id="542" Count="1" />
      <LineId Id="539" Count="0" />
      <LineId Id="520" Count="5" />
      <LineId Id="554" Count="0" />
      <LineId Id="526" Count="6" />
      <LineId Id="500" Count="0" />
    </LineIds>
  </POU>
</TcPlcObject>