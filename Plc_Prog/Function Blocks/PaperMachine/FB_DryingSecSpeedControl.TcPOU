<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="FB_DryingSecSpeedControl" Id="{ad443758-a473-4c6b-9f2b-bb729df2a765}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_DryingSecSpeedControl
VAR_INPUT
    //==============================================================
    // ─────────────── MODE SELECTION / REFERENCES ───────────────
    //==============================================================
    groupSpeedAutoMan          : BOOL;  // TRUE = Auto, FALSE = Manual
    groupAutoSpeedMPM          : REAL;  // Auto speed reference [m/min]
    groupManualSpeedMPM        : REAL;  // Manual speed reference [m/min]
    groupRecoverSpeedCmd       : BOOL;  // Recover (temporary speed bump)
    groupRecoverIncrement      : REAL;  // Recover increment [m/min]
//    interGroupGearRatio        : REAL;  // Inter-group ratio (next section sync)

	upperSlaveRatio				: REAL := 1;
	lowerSlaveRatio				: REAL := 1;
	
    //==============================================================
    // ─────────────── DIAMETERS (mm) ───────────────
    //==============================================================
    upperMasterDiameter       : REAL;  // Diameter of group 1 master
    upperSlaveDiameter       : REAL;  // Diameter of group 1 slave 1

    lowerMasterDiameter       : REAL;  // Diameter of group 2 master
    lowerSlaveDiameter       : REAL;  // Diameter of group 2 slave 1

    //==============================================================
    // ─────────────── CONFIGURATION / LIMITS ───────────────
    //==============================================================
    groupMasterMaxSpeedRPM     : REAL;  // Max allowed master RPM
    rampUpRate					: REAL := 0.1;  // Ramp acceleration [RPM/s]
    rampDownRate				: REAL := 0.1;  // Ramp acceleration [RPM/s]
    rampUpRate2					: REAL := 0.1;  // Ramp acceleration [RPM/s]
    rampDownRate2				: REAL := 0.1;  // Ramp acceleration [RPM/s]

	
    state                      : INT;   // Machine state (5 = STOPPING)

	speedDifIncPerPulse		: REAL := 0.05;
	
    groupSpeedDifInc           : BOOL;  // Increment group speed offset
    groupSpeedDifDec           : BOOL;  // Decrement group speed offset
    groupSpeedDifLimLow        : REAL;  // Min offset [%]
    groupSpeedDifLimHigh       : REAL;  // Max offset [%]

    upperAndLowerSpeedOffset   : REAL;  // Bias [%] between group1 and group2
	upperAndLowerSpeedCalibration   : REAL;  // Bias [%] between upper and lower

    rampReset                  : BOOL;  // Reset ramp command
	
	paperPresenceSensor 		: BOOL;
	
END_VAR


VAR_OUTPUT
    //==============================================================
    // ─────────────── FINAL DRIVE SPEEDS (RPM) ───────────────
    //==============================================================
    upperMasterRefRPM    : REAL;
    upperSlaveRefRPM    : REAL;

    lowerMasterRefRPM    : REAL;
    lowerSlaveRefRPM    : REAL;


    //==============================================================
    // ─────────────── SURFACE SPEEDS (MPM) ───────────────
    //==============================================================
    upperMasterRefMPM       : REAL;
    upperSlaveRefMPM       : REAL;

    lowerMasterRefMPM       : REAL;
    lowerSlaveRefMPM       : REAL;

    //==============================================================
    // ─────────────── HANDOFF TO NEXT GROUP ───────────────
    //==============================================================
    nextGroupSpeedRefMPM       : REAL;
	speedDif					: REAL;
	
END_VAR


VAR
    //==============================================================
    // ─────────────── INTERNAL CALCULATION VARIABLES ───────────────
    //==============================================================
    masterMaxSpeedMPM          : REAL;
    baseCmdSpeedMPM            : REAL;
    cmdSpeedMPM                : REAL;
    targetRPM                  : REAL;
    rampTargetRPM              : REAL;
    baseMasterRefRPM           : REAL;
    groupSpeedOffset           : REAL;
    groupDeltaRatioAll         : REAL;
    upperLowerBiasRatio        : REAL;
    useRamp                    : BOOL;
    epsDiameter                : REAL := 0.001;

    // Gear ratios (set externally or calculated elsewhere)
    group1ToGroup1Slave1Ratio  : REAL := 1.0;
    group1ToGroup1Slave2Ratio  : REAL := 1.0;
    group1ToGroup2MasterRatio  : REAL := 1.0;
    group2ToGroup2Slave1Ratio  : REAL := 1.0;
    group2ToGroup2Slave2Ratio  : REAL := 1.0;

    // Function blocks
    instFB_Gen_SRamp           : FB_Gen_SRamp;
    instFB_SpeedDif_SRamp           : FB_Gen_SRamp;

	rampActive: BOOL;
END_VAR


VAR PERSISTENT
	
    instTUNE2_GroupSpeedDiff   : TUNE2;

END_VAR


(*

IF 	paperPresenceSensor THEN
	//slow	
	instFB_Gen_SRamp.A_UP := MAX(0.0, rampUpRate);
	instFB_Gen_SRamp.A_DN := -MAX(0.0, rampDownRate);

ELSE
	//fast
	instFB_Gen_SRamp.A_UP := MAX(0.0, rampUpRate2);
	instFB_Gen_SRamp.A_DN := -MAX(0.0, rampDownRate2);

END_IF


// Ramp function block execution
instFB_Gen_SRamp(
    X          := rampTargetRPM,
//    A_UP       := MAX(0.0, rampUpRate),
//    A_DN       := -MAX(0.0, rampDownRate),
    VU_MAX     := 1000.0,
    VD_MAX     := -1000.0,
    LIMIT_HIGH := groupMasterMaxSpeedRPM,
    RST        := rampReset);


*)
]]></Declaration>
    <Implementation>
      <ST><![CDATA[//==============================================================
// IMPLEMENTATION
//==============================================================

//====================================================================
// ═══ CALL METHOD TO CALCULATE DIAMETER RATIOS ═════════════════════
//====================================================================
_CalculateGearRatios();

//--------------------------------------------------------------
// Calculate master max surface speed [m/min]
//--------------------------------------------------------------
masterMaxSpeedMPM := groupMasterMaxSpeedRPM * (PI * upperMasterDiameter) / 1000.0;


//--------------------------------------------------------------
// Determine base speed source (auto/manual) + Recover bump
//--------------------------------------------------------------
IF groupSpeedAutoMan THEN
    baseCmdSpeedMPM := groupAutoSpeedMPM;
ELSE
    baseCmdSpeedMPM := groupManualSpeedMPM;
END_IF;

IF groupRecoverSpeedCmd THEN
    cmdSpeedMPM := baseCmdSpeedMPM + groupRecoverIncrement;
ELSE
    cmdSpeedMPM := baseCmdSpeedMPM;
END_IF;


//--------------------------------------------------------------
// Convert MPM → target RPM for the master
//--------------------------------------------------------------
targetRPM := _Scale(
    X    := cmdSpeedMPM,
    I_LO := 0.0,
    I_HI := masterMaxSpeedMPM,
    O_LO := 0.0,
    O_HI := groupMasterMaxSpeedRPM);


//--------------------------------------------------------------
// Ramp handling
//--------------------------------------------------------------
IF state = 5 OR state = 0 THEN
    // STOPPING — force ramp down to zero speed
    rampTargetRPM := 0.0;

ELSIF state = 10 THEN
    // FAULT — clear ramp immediately to ensure no residual motion
    rampTargetRPM := 0.0;
//    rampReset     := TRUE;

ELSE
    // Normal operation — ramp follows target speed
    rampTargetRPM := targetRPM;
//    rampReset     := FALSE;
END_IF;

// Detect when a new target speed change requires ramping
IF NOT (rampActive AND ABS(rampTargetRPM - baseMasterRefRPM) >= 0.05) OR NOT paperPresenceSensor THEN
   rampActive := TRUE; // Rising edge — ramp request detected
 
END_IF;


IF 	paperPresenceSensor THEN
	//slow	
	instFB_Gen_SRamp.A_UP := MAX(0.0, rampUpRate);
	instFB_Gen_SRamp.A_DN := -MAX(0.0, rampDownRate);

ELSE
	//fast
	instFB_Gen_SRamp.A_UP := MAX(0.0, rampUpRate2);
	instFB_Gen_SRamp.A_DN := -MAX(0.0, rampDownRate2);

END_IF


// Ramp function block execution
instFB_Gen_SRamp(
    X          := rampTargetRPM,
    VU_MAX     := 1000.0,
    VD_MAX     := -1000.0,
    LIMIT_HIGH := groupMasterMaxSpeedRPM,
    RST        := rampReset);


// If ramping, update the baseMasterRefRPM from ramp output
IF rampActive THEN
    baseMasterRefRPM := instFB_Gen_SRamp.Y;

    // Automatically reset ramp flag when the ramp output reaches the target
    IF ABS(instFB_Gen_SRamp.Y - rampTargetRPM) <= 0.05 THEN
        rampActive := FALSE; // Ramp complete
    END_IF;

ELSE
    // No ramping required — direct assignment
    baseMasterRefRPM := rampTargetRPM;
END_IF;


//--------------------------------------------------------------
// Operator offset (TUNE2 control)
//--------------------------------------------------------------
instTUNE2_GroupSpeedDiff(
    SET     := FALSE,
    SU      := groupSpeedDifInc,
    SD      := groupSpeedDifDec,
    RST     := FALSE,
    SS      := speedDifIncPerPulse,
    FS      := speedDifIncPerPulse,
    LIMIT_L := groupSpeedDifLimLow,
    LIMIT_H := groupSpeedDifLimHigh,
    Y       => groupSpeedOffset);

	
speedDif := groupSpeedOffset;
	
groupDeltaRatioAll  := 1.0 + (groupSpeedOffset * 0.01);
upperLowerBiasRatio := 1.0 + ((upperAndLowerSpeedOffset + upperAndLowerSpeedCalibration) * 0.01);


//--------------------------------------------------------------
// Apply offsets + calculate all drive RPM references
//--------------------------------------------------------------
upperMasterRefRPM := baseMasterRefRPM * groupDeltaRatioAll;
upperSlaveRefRPM := upperMasterRefRPM  * upperSlaveRatio;


lowerMasterRefRPM := upperMasterRefRPM * group1ToGroup2MasterRatio;
lowerSlaveRefRPM := lowerMasterRefRPM * lowerSlaveRatio;


//--------------------------------------------------------------
// Convert RPM → MPM (surface speeds)
//--------------------------------------------------------------
upperMasterRefMPM := upperMasterRefRPM * upperMasterDiameter * PI / 1000.0;
upperSlaveRefMPM := (upperSlaveRefRPM * upperSlaveDiameter * PI / 1000.0);


lowerMasterRefMPM := lowerMasterRefRPM * lowerMasterDiameter * PI / 1000.0;
lowerSlaveRefMPM := (lowerSlaveRefRPM * lowerSlaveDiameter * PI / 1000.0);


//--------------------------------------------------------------
// Suggest downstream handoff (group2 master surface speed)
//--------------------------------------------------------------
nextGroupSpeedRefMPM := upperMasterRefMPM;
]]></ST>
    </Implementation>
    <Method Name="_CalculateGearRatios" Id="{502fc3db-3266-4f84-8189-72e67a8be079}">
      <Declaration><![CDATA[
//====================================================================
// ═══ PRIVATE METHOD — CALCULATE DIAMETER RATIOS ════════════════════
//====================================================================
METHOD PRIVATE _CalculateGearRatios
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
//──────────────────────────────────────────────────────────────
// Gear Ratios — Group 1 (Reference: Group1 Master)
//──────────────────────────────────────────────────────────────
IF upperMasterDiameter > 0.0 THEN
    group1ToGroup2MasterRatio := upperMasterDiameter / lowerMasterDiameter;
    group1ToGroup1Slave1Ratio := upperMasterDiameter / upperSlaveDiameter;
ELSE
    group1ToGroup2MasterRatio := 0.0;
    group1ToGroup1Slave1Ratio := 0.0;
END_IF;

//──────────────────────────────────────────────────────────────
// Gear Ratios — Group 2 (Reference: Group2 Master)
//──────────────────────────────────────────────────────────────
IF lowerMasterDiameter > 0.0 THEN
    group2ToGroup2Slave1Ratio := lowerMasterDiameter / lowerSlaveDiameter;
ELSE
    group2ToGroup2Slave1Ratio := 0.0;
END_IF;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_Scale" Id="{a5e6ce6b-d557-440d-b84b-9740cba84b5d}">
      <Declaration><![CDATA[METHOD PRIVATE _Scale : REAL
VAR_INPUT
    X    : REAL;
    I_LO : REAL;
    I_HI : REAL;
    O_LO : REAL;
    O_HI : REAL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF I_LO = I_HI THEN
	_Scale := O_LO;
ELSE
	_Scale := (O_HI - O_LO) / (I_HI - I_LO) * (LIMIT(I_LO, X, I_HI) - I_LO) + O_LO;
END_IF;
]]></ST>
      </Implementation>
    </Method>
    <LineIds Name="FB_DryingSecSpeedControl">
      <LineId Id="1645" Count="150" />
      <LineId Id="9" Count="0" />
    </LineIds>
    <LineIds Name="FB_DryingSecSpeedControl._CalculateGearRatios">
      <LineId Id="13" Count="6" />
      <LineId Id="21" Count="2" />
      <LineId Id="25" Count="6" />
      <LineId Id="33" Count="1" />
      <LineId Id="5" Count="0" />
    </LineIds>
    <LineIds Name="FB_DryingSecSpeedControl._Scale">
      <LineId Id="1" Count="5" />
    </LineIds>
  </POU>
</TcPlcObject>