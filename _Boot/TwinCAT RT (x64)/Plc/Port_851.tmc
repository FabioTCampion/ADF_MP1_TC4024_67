ateTime></Default><Properties><Property><Name>ItemType</Name><Value>Input</Value></Property></Properties></SubItem><SubItem><Name>stallDeltaMin_mm</Name><Type>REAL</Type><Comment><![CDATA[ Minimum position change to consider progress [mm]]]></Comment><BitSize>32</BitSize><BitOffs>448</BitOffs><Default><Value>0.02</Value></Default><Properties><Property><Name>ItemType</Name><Value>Input</Value></Property></Properties></SubItem><SubItem><Name>stallTimeout</Name><Type>TIME</Type><Comment><![CDATA[ No-progress duration => stall fault]]></Comment><BitSize>32</BitSize><BitOffs>480</BitOffs><Default><DateTime>T</DateTime></Default><Properties><Property><Name>ItemType</Name><Value>Input</Value></Property></Properties></SubItem><SubItem><Name>travelTimeout</Name><Type>TIME</Type><Comment><![CDATA[ Max time allowed to reach target => timeout fault]]></Comment><BitSize>32</BitSize><BitOffs>512</BitOffs><Default><DateTime>T</DateTime></Default><Properties><Property><Name>ItemType</Name><Value>Input</Value></Property></Properties></SubItem><SubItem><Name>openingCmd</Name><Type>BOOL</Type><Comment><![CDATA[ Command: open direction (PWM-modulated in Auto)]]></Comment><BitSize>8</BitSize><BitOffs>544</BitOffs><Properties><Property><Name>ItemType</Name><Value>Output</Value></Property></Properties></SubItem><SubItem><Name>closingCmd</Name><Type>BOOL</Type><Comment><![CDATA[ Command: close direction (PWM-modulated in Auto)]]></Comment><BitSize>8</BitSize><BitOffs>552</BitOffs><Properties><Property><Name>ItemType</Name><Value>Output</Value></Property></Properties></SubItem><SubItem><Name>busy</Name><Type>BOOL</Type><Comment><![CDATA[ TRUE while moving (Auto or Manual jog)]]></Comment><BitSize>8</BitSize><BitOffs>560</BitOffs><Properties><Property><Name>ItemType</Name><Value>Output</Value></Property></Properties></SubItem><SubItem><Name>done</Name><Type>BOOL</Type><Comment><![CDATA[ TRUE after successful auto positioning]]></Comment><BitSize>8</BitSize><BitOffs>568</BitOffs><Properties><